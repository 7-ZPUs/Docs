@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
title Component Diagram per il Main Process di DipReader

Component_Ext(filesystem, "File System Locale", "File System", "Fornisce il pacchetto DIP originario e funge da destinazione per i file esportati/scaricati.")
Component_Ext(sqlite, "Relational Database", "SQLite3", "Memorizza i metadati XML indicizzati.")
Component_Ext(sqlite_vss, "Vector Database", "SQLite3 + sqlite-vss", "Memorizza i vettori generati per la ricerca semantica.")
Component_Ext(renderer, "Renderer UI", "Angular, TypeScript", "Fornisce l'interfaccia visiva per la navigazione, la ricerca e la visualizzazione dei documenti.")

Container_Boundary(main, "Main Process") {
    Component(ipc_handler, "IPC Handler", "Node.js, TypeScript", "Gestisce tutte le comunicazioni IPC con il frontend Angular.")
    Component(dip_importer, "DIP Importer", "Node.js, TypeScript", "Gestisce l'accesso al disco e l'estrazione dei file fisici e XML dal pacchetto DIP.")
    Component(metadata_parser, "Metadata Parser", "Node.js, TypeScript", "Effettua il parsing e la validazione dei file XML, preparando i dati per l'indicizzazione.")
    Component(indexer, "Indexer", "Node.js, TypeScript", "Indicizza i metadati estratti e li memorizza nel database SQLite.")
    Component(semantic_indexer, "Semantic Indexer", "Node.js, TypeScript", "Genera vettori semantici dai metadati e li memorizza nel database SQLite.")
    Component(search_engine, "Search Engine", "Node.js, TypeScript", "Gestisce le query di ricerca testuale utilizzando il database SQLite.")
    Component(sema_search_engine, "Semantic Search Engine", "Node.js, TypeScript", "Gestisce le query di ricerca semantica utilizzando i vettori e i modelli LLM.")
    Component(verification_engine, "Verification Engine", "Node.js, TypeScript", "Verifica l'integrità e l'autenticità dei file nel DIP.")
    Component(export_manager, "Export Manager", "Node.js, TypeScript", "Gestisce l'estrazione dei file dal DIP per la stampa o il download.")
    Component(dbManager, "Database Manager", "Node.js, TypeScript", "Gestisce le operazioni di lettura/scrittura sui metadati nel database SQLite.")
    Component(sema_dbManager, "Semantic DB Manager", "Node.js, TypeScript", "Gestisce i vettori semantici nel database SQLite-VSS.")
    Component(llm_inference, "LLM Inference Engine", "transformers.js, TypeScript", "Gestisce l'inferenza con modelli LLM locali per la ricerca semantica.")
}

Rel(ipc_handler, dip_importer, "Richieste di importazione DIP")
Rel(ipc_handler, search_engine, "Query di ricerca testuale")
Rel(ipc_handler, sema_search_engine, "Query di ricerca semantica")
Rel(ipc_handler, verification_engine, "Richieste di verifica integrità")
Rel(ipc_handler, export_manager, "Richieste di esportazione file")
Rel(ipc_handler, renderer, "Risposte al frontend via IPC")
Rel(dip_importer, metadata_parser, "Invia i file XML grezzi estratti")
Rel(metadata_parser, indexer, "Invia dati strutturati per l'indicizzazione")
Rel(metadata_parser, semantic_indexer, "Invia dati strutturati per la vettorizzazione")
Rel(indexer, dbManager, "Memorizza i metadati indicizzati")
Rel(semantic_indexer, sema_dbManager, "Memorizza i vettori semantici")
Rel(search_engine, dbManager, "Legge i metadati")
Rel(sema_search_engine, sema_dbManager, "Legge i vettori semantici")
Rel(sema_search_engine, llm_inference, "Utilizza i modelli LLM")
Rel(dbManager, sqlite, "Lettura/scrittura")
Rel(sema_dbManager, sqlite_vss, "Lettura/scrittura")
Rel(verification_engine, dbManager, "Accede ai metadati per la verifica")
Rel(export_manager, filesystem, "Accede ai file DIP per l'esportazione")
Rel(verification_engine, filesystem, "Legge i file DIP per il ricalcolo degli hash e la verifica")


@enduml