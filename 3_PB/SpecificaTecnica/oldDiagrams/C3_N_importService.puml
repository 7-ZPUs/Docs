@startuml Import & Indexing Service - Main Process
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
title Import & Indexing Service - Main Process

Component_Ext(filesystem,   "File System Locale", "File System",       "Fornisce il pacchetto DIP compresso.")
Component_Ext(sqlite_db,    "SQLite Database",    "SQLite3 + sqlite-vss", "Ospita tabelle relazionali (metadati) e tabelle VSS (vettori).")
Component_Ext(llm_inference,"LLM Inference Engine","ONNX Runtime",     "Servizio condiviso per la generazione di embeddings. Vedere diagramma Query Service.")
Component_Ext(import_ipc,   "Import IPC Handler", "Node.js, TypeScript","Dispatcher IPC che avvia il pipeline.")

Container_Boundary(import_svc, "Import & Indexing Service") {

    Component(dip_importer, "DIP Importer", "Node.js, TypeScript","Orchestratore puro del pipeline:\nFileReader → MetadataParser → [ IIndexer ].\nNessuna logica I/O o di parsing propria.")

    Component(file_reader, "DIP File Reader", "Node.js, TypeScript","<<IFileReader>>\nSRP: responsabilità unica di accesso I/O.\nLegge e decomprime il pacchetto DIP.\nNon conosce la struttura XML.")

    Component(metadata_parser, "Metadata Parser", "Node.js, TypeScript","SRP: parsing e validazione XML AGID.\nProduce DTO normalizzati.\nNon dipende da nessun DB né da IFileReader.")

    Component(indexer, "Metadata Indexer", "Node.js, TypeScript","<<IIndexer>>\nPersiste i metadati strutturati nel\nrepository relazionale.")

    Component(semantic_indexer, "Semantic Indexer", "Node.js, TypeScript","<<IIndexer>>\nGenera embeddings tramite LLM Inference\ne li persiste nel repository vettoriale.")

    Component(metadata_repo, "Metadata Repository", "Node.js, TypeScript","<<IMetadataRepository>>\nDIP: astrazione CRUD relazionale.\nIsola tutti i componenti da SQLite.")

    Component(vector_repo, "Vector Repository", "Node.js, TypeScript","<<IVectorRepository>>\nDIP: astrazione CRUD vettoriale.\nIsola i componenti da sqlite-vss.")

    note as indexer_note
      OCP + DIP: MetadataParser conosce solo
      l'interfaccia IIndexer. Aggiungere un nuovo
      tipo di indicizzazione = nuova classe,
      zero modifiche al parser.
    end note
}

Rel(import_ipc,   dip_importer,    "Avvia importazione")
Rel(dip_importer, file_reader,     "Legge file fisici dal DIP", "IFileReader")
Rel(dip_importer, metadata_parser, "Passa bytes XML grezzi")
Rel(metadata_parser, indexer,          "Invia DTO strutturati", "IIndexer")
Rel(metadata_parser, semantic_indexer, "Invia DTO strutturati", "IIndexer")

Rel(indexer,          metadata_repo, "Persiste metadati",  "IMetadataRepository")
Rel(semantic_indexer, vector_repo,   "Persiste vettori",   "IVectorRepository")
Rel(semantic_indexer, llm_inference, "Genera embeddings")

Rel(file_reader,  filesystem, "Legge e decomprime il DIP", "Node.js fs")
Rel(metadata_repo, sqlite_db, "Lettura/Scrittura tabelle relazionali", "SQLite Driver")
Rel(vector_repo,   sqlite_db, "Lettura/Scrittura tabelle VSS",         "SQLite Driver")

@enduml
