@startuml Component Diagram - Search
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
title Component Diagram - Search\n(search:classes, search:processes, search:documents, search:semantic, search:ai-state)

LAYOUT_TOP_DOWN()
skinparam linetype ortho
skinparam shadowing false
skinparam wrapWidth 200
skinparam nodesep 60
skinparam ranksep 60

Component_Ext(renderer,  "Renderer Process", "Angular / TypeScript", "Invia comandi di ricerca via IPC bridge.")
Component_Ext(sqlite_db, "SQLite Database",  "SQLite3",              "Tabelle relazionali metadati e vettori embedding.")
Component_Ext(ai_model,  "AI Model",         "ONNX / Local LLM",    "Modello locale per la generazione di word embedding.")

Container_Boundary(main, "Main Process - Electron") {

    Component(search_ipc, "SearchIpcAdapter", "Node.js / TypeScript","Canali: search:classes, search:processes,\nsearch:documents, search:semantic, search:ai-state")
    Component(uc_search_classi,    "SearchDocumentalClassUC", "Node.js / TypeScript", "Ricerca classi documentali per nome con filtri AND.")
    Component(uc_search_processi,  "SearchProcessiUC",          "Node.js / TypeScript", "Ricerca processi archivistici per UUID con filtri AND.")
    Component(uc_search_documenti, "SearchDocumentsUC",         "Node.js / TypeScript", "Ricerca documenti per metadati con filtri AND.")
    Component(uc_search_semantic,  "SearchSemanticUC",          "Node.js / TypeScript", "Genera embedding della query e trova documenti per similarita' vettoriale. Espone lo stato del modello AI locale.")
    Component(port_search,    "PackageSearchPort",   "Interface",                "searchClasses(name), searchProcesses(uuid),\nsearchDocument(filters[]), searchDocumentSemantic(query).")
    Component(adapter_sqlite, "SqlitePackageAdapter","Node.js / better-sqlite3", "Implementa PackageSearchPort su tabelle SQLite\n(SQL LIKE + KNN vettoriale).")
    Component(port_embedding, "WordEmbeddingPort",   "Interface",                "generateEmbedding(text): Promise<Vector>")
    Component(adapter_ai,     "LocalAiAdapter",      "Node.js / ONNX Runtime",   "Implementa WordEmbeddingPort.\nEsegue inferenza sul modello locale.")
}

Rel_D(renderer, search_ipc, "search:*", "Electron IPC")
Rel_D(search_ipc, uc_search_classi,    "search:classes")
Rel_D(search_ipc, uc_search_processi,  "search:processes")
Rel_D(search_ipc, uc_search_documenti, "search:documents")
Rel_D(search_ipc, uc_search_semantic,  "search:semantic, search:ai-state")
Rel_D(uc_search_classi,    port_search,    "searchClasses(name)")
Rel_D(uc_search_processi,  port_search,    "searchProcesses(uuid)")
Rel_D(uc_search_documenti, port_search,    "searchDocument(filters[])")
Rel_D(uc_search_semantic,  port_embedding, "generateEmbedding(query)")
Rel_D(uc_search_semantic,  port_search,    "searchDocumentSemantic(vector)")
Rel_D(port_search,    adapter_sqlite, "implementa")
Rel_D(port_embedding, adapter_ai,     "implementa")
Rel_D(adapter_sqlite, sqlite_db, "Read (SQL LIKE / KNN vettoriale)")
Rel_D(adapter_ai,     ai_model,  "Inference (generazione embedding)")
@enduml