@startuml Component Diagram – File IPC
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
title Component Diagram – File IPC (file:get-by-id, file:get-by-document, file:get-path, file:get-metadata, file:read, file:open-external, file:open-in-window, file:download, file:check-integrity, file:get-integrity-status, file:save-integrity)

LAYOUT_TOP_DOWN()
skinparam linetype ortho
skinparam shadowing false
skinparam wrapWidth 200
skinparam nodesep 60
skinparam ranksep 60

' ══════════════════════════════════════════════════════════════
'  SISTEMI ESTERNI
' ══════════════════════════════════════════════════════════════

Component_Ext(renderer,   "Renderer Process", "Angular, TypeScript",  "Invia comandi via IPC bridge.")
Component_Ext(sqlite_db,  "SQLite Database",  "SQLite3",              "Tabelle relazionali metadati.")
Component_Ext(filesystem, "File System",      "OS File System",       "Pacchetto DIP e destinazione export.")
Component_Ext(printer_hw, "Stampante",        "OS Print API",         "Dispositivo di output per la stampa.")

Container_Boundary(main, "Main Process – Electron") {

    ' ── Driving Adapter ─────────────────────────────────────
    Component(file_ipc, "File IPC Adapter", "Node.js, TypeScript", "Canali: file:get-by-id, file:get-by-document, file:get-path, file:get-metadata, file:read, file:open-external, file:open-in-window, file:download, file:check-integrity, file:get-integrity-status, file:save-integrity")

    ' ── Use Cases ────────────────────────────────────────────
    Component(uc_get_file,           "GetFileById",         "Node.js, TypeScript", "Recupera file per ID.")
    Component(uc_status_file,        "GetFilesByStatus",    "Node.js, TypeScript", "Filtra file per stato di integrità.")
    Component(uc_open,               "OpenFile",            "Node.js, TypeScript", "Apre file con app di sistema o finestra Electron.")
    Component(uc_export,             "ExportFile",          "Node.js, TypeScript", "Salva file su disco utente nella destinazione scelta.")
    Component(uc_integrity_file,     "CheckFileIntegrity",  "Node.js, TypeScript", "Calcola SHA256 del file e confronta con hash atteso.")

    ' ── Ports ────────────────────────────────────────────────
    Component(port_reader, "PackageReaderPort", "TypeScript Interface", "<<Port>> getFileContent(), readFileBytes(), openReadStream().")
    Component(port_export, "FileExportPort",    "TypeScript Interface", "<<Port>> exportFile(destPath, content), openWriteStream(destPath, source).")
    Component(port_print,  "PrintPort",         "TypeScript Interface", "<<Port>> printFile(buffer), printFileStream(source).")

    ' ── Repositories ─────────────────────────────────────────
    Component(repo_file,      "FileRepository",      "TypeScript Interface", "<<Repository>> findById(), findByDocument(), getPhysicalPath(), save().")
    Component(repo_metadata,  "MetadataRepository",  "TypeScript Interface", "<<Repository>> findByFile(), findByDocument().")
    Component(repo_integrity, "IntegrityRepository", "TypeScript Interface", "<<Repository>> save(), findByFile().")

    ' ── Driven Adapters ──────────────────────────────────────
    Component(adapt_sqlite_file,      "SQLiteFileRepository",       "better-sqlite3", "Implementa FileRepository.")
    Component(adapt_sqlite_metadata,  "SQLiteMetadataRepository",   "better-sqlite3", "Implementa MetadataRepository.")
    Component(adapt_sqlite_integrity, "SQLiteIntegrityRepository",  "better-sqlite3", "Implementa IntegrityRepository.")
    Component(adapt_reader,           "FileSystemPackageReaderAdapter", "Node.js fs", "Implementa PackageReaderPort.")
    Component(adapt_export,           "FileSystemExportAdapter",    "Node.js fs", "Implementa FileExportPort.")
    Component(adapt_printer,          "PrinterPrintPortAdapter",    "Node.js", "Implementa PrintPort.")
}

' ── Renderer → IPC ───────────────────────────────────────────
Rel_D(renderer, file_ipc, "file:*", "Electron IPC")

' ── IPC → Use Cases ──────────────────────────────────────────
Rel_D(file_ipc, uc_get_file,       "file:get-by-id\nfile:get-path\nfile:get-metadata")
Rel_R(file_ipc, uc_status_file,    "file:get-by-status")
Rel_R(file_ipc, uc_open,           "file:open-external\nfile:open-in-window\nfile:read")
Rel_R(file_ipc, uc_export,         "file:download")
Rel_R(file_ipc, uc_integrity_file, "file:check-integrity\nfile:get-integrity-status\nfile:save-integrity")

' ── Use Cases → Repositories / Ports ─────────────────────────
Rel_D(uc_get_file,       repo_file,       "Legge file per ID")
Rel_R(uc_get_file,       repo_metadata,   "Legge metadati file")
Rel_D(uc_status_file,    repo_file,       "Filtra per stato integrità")
Rel_D(uc_open,           repo_file,       "Legge percorso fisico")
Rel_R(uc_open,           port_reader,     "Legge contenuto file")
Rel_D(uc_export,         repo_file,       "Legge percorso fisico")
Rel_D(uc_export,         port_reader,     "Legge file da esportare")
Rel_R(uc_export,         port_export,     "Salva su disco")
Rel_R(uc_export,         port_print,      "Stampa documento")
Rel_D(uc_integrity_file, repo_file,       "Legge hash atteso")
Rel_R(uc_integrity_file, repo_integrity,  "Legge/salva stato integrità")
Rel_D(uc_integrity_file, port_reader,     "Legge file per calcolo hash")

' ── Repositories → Adapters ──────────────────────────────────
Rel_D(repo_file,      adapt_sqlite_file,      "impl.")
Rel_D(repo_metadata,  adapt_sqlite_metadata,  "impl.")
Rel_D(repo_integrity, adapt_sqlite_integrity, "impl.")

' ── Ports → Adapters ─────────────────────────────────────────
Rel_D(port_reader, adapt_reader,  "impl.")
Rel_D(port_export, adapt_export,  "impl.")
Rel_D(port_print,  adapt_printer, "impl.")

' ── Adapters → Sistemi Esterni ───────────────────────────────
Rel_D(adapt_sqlite_file,      sqlite_db,  "CRUD")
Rel_D(adapt_sqlite_metadata,  sqlite_db,  "CRUD")
Rel_D(adapt_sqlite_integrity, sqlite_db,  "CRUD")
Rel_D(adapt_reader,           filesystem, "Lettura DIP")
Rel_D(adapt_export,           filesystem, "Scrittura export")
Rel_D(adapt_printer,          printer_hw, "Invio stampa")

@enduml
