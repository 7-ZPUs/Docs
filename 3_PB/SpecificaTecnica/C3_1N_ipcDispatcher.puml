@startuml IPC Dispatch Layer - Main Process
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
title IPC Dispatch Layer - Main Process

Component_Ext(renderer, "Renderer Process", "Angular, TypeScript", "Interfaccia utente che invia comandi e riceve risposte via IPC.")

Component_Ext(import_service,       "Import & Indexing Service", "Node.js, TypeScript", "Gestisce il pipeline di importazione e indicizzazione del DIP.")
Component_Ext(query_service,        "Query Service",             "Node.js, TypeScript", "Gestisce le query di ricerca testuale e semantica.")
Component_Ext(verification_service, "Verification Service",      "Node.js, TypeScript", "Verifica integrità, firme e sigilli elettronici.")
Component_Ext(export_service,       "Export & Print Service",    "Node.js, TypeScript", "Gestisce esportazione file e stampa.")

Container_Boundary(ipc_layer, "IPC Dispatch Layer") {

    note as ocp_note
      OCP: ogni handler registra i propri canali IPC.
      Aggiungere una nuova feature = aggiungere
      un nuovo handler, senza modificare gli esistenti.
    end note

    Component(import_ipc,       "Import IPC Handler",       "Node.js, TypeScript", "Canali IPC: dip:load, dip:status.\nReceve richieste di importazione e risponde con lo stato di avanzamento.")
    Component(search_ipc,       "Search IPC Handler",       "Node.js, TypeScript", "Canali IPC: search:text, search:semantic.\nDelega a ISearchEngine senza conoscere l'implementazione concreta.")
    Component(verification_ipc, "Verification IPC Handler", "Node.js, TypeScript", "Canali IPC: verify:integrity, verify:signature.\nAvvia la verifica e restituisce il report.")
    Component(export_ipc,       "Export IPC Handler",       "Node.js, TypeScript", "Canali IPC: export:file, export:print.\nOrchestra esportazione e stampa.")
}

Rel(renderer, import_ipc,       "dip:load, dip:status",         "Electron IPC / Context Bridge")
Rel(renderer, search_ipc,       "search:text, search:semantic", "Electron IPC / Context Bridge")
Rel(renderer, verification_ipc, "verify:integrity, verify:signature", "Electron IPC / Context Bridge")
Rel(renderer, export_ipc,       "export:file, export:print",    "Electron IPC / Context Bridge")

Rel(import_ipc,       import_service,       "Avvia pipeline di importazione")
Rel(search_ipc,       query_service,        "Invia query via ISearchEngine")
Rel(verification_ipc, verification_service, "Avvia verifica")
Rel(export_ipc,       export_service,       "Avvia esportazione/stampa")

@enduml
