@startuml Diagramma delle Classi – ClasseDocumentale IPC
title Diagramma delle Classi – ClasseDocumentale IPC

' ══════════════════════════════════════════════════════════════
'  Entità principali
' ══════════════════════════════════════════════════════════════
class ClasseDocumentale {
	- id: string
	- metadati: Metadato []
	- stato: StatoClasse
	- hash: string
}

class Metadato {
	- name: string
    - value: string
    - type: string
}

enum StatoClasse {
	Valida
	NonValida
	DaVerificare
}

' ══════════════════════════════════════════════════════════════
'  Repository e Port
' ══════════════════════════════════════════════════════════════
interface PackageReaderPort {
	+readFileBytes(path: string): byte[]
	+getDocumentMetadata(path: string): MetadatiClasse
}

class ClasseDocumentaleRepository {
	+getById(id: string): ClasseDocumentale
	+search(filtro: FiltroClasse): ClasseDocumentale[]
	+getByStatus(stato: StatoClasse): ClasseDocumentale[]
	+getExpectedHash(id: string): string
}

' ══════════════════════════════════════════════════════════════
'  Use Case
' ══════════════════════════════════════════════════════════════
class GetClasseDocumentaleByIdUC {
	+execute(id: string): ClasseDocumentale
}

class SearchClassiDocumentaliUC {
	+execute(filtro: FiltroClasse): ClasseDocumentale[]
}

class GetClassiDocumentaliByStatusUC {
	+execute(stato: StatoClasse): ClasseDocumentale[]
}

class CheckClasseDocumentaleIntegrityUC {
	+execute(id: string): boolean
}

' ══════════════════════════════════════════════════════════════
'  Adapter
' ══════════════════════════════════════════════════════════════
class ClasseDocumentaleIPCAdapter {
	+getById(id: string): ClasseDocumentale
	+search(filtro: FiltroClasse): ClasseDocumentale[]
	+getByStatus(stato: StatoClasse): ClasseDocumentale[]
	+checkIntegrity(id: string): boolean
}

' ══════════════════════════════════════════════════════════════
'  Relazioni
' ══════════════════════════════════════════════════════════════
ClasseDocumentale *-- Metadato
GetClasseDocumentaleByIdUC --> ClasseDocumentaleRepository : usa
SearchClassiDocumentaliUC --> ClasseDocumentaleRepository : usa
GetClassiDocumentaliByStatusUC --> ClasseDocumentaleRepository : usa
CheckClasseDocumentaleIntegrityUC --> ClasseDocumentaleRepository : usa
CheckClasseDocumentaleIntegrityUC --> PackageReaderPort : usa
ClasseDocumentaleIPCAdapter --> GetClasseDocumentaleByIdUC
ClasseDocumentaleIPCAdapter --> SearchClassiDocumentaliUC
ClasseDocumentaleIPCAdapter --> GetClassiDocumentaliByStatusUC
ClasseDocumentaleIPCAdapter --> CheckClasseDocumentaleIntegrityUC

note right of ClasseDocumentaleRepository
	Implementazione con better-sqlite3
end note

@enduml
