@startuml Component Diagram – AI IPC
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
title Component Diagram – AI IPC (ai:init, ai:state, ai:search, ai:generate-embedding, ai:reindex-all, ai:clear)

LAYOUT_TOP_DOWN()
skinparam linetype ortho
skinparam shadowing false
skinparam wrapWidth 200
skinparam nodesep 60
skinparam ranksep 60

' ══════════════════════════════════════════════════════════════
'  SISTEMI ESTERNI
' ══════════════════════════════════════════════════════════════

Component_Ext(renderer,  "Renderer Process", "Angular, TypeScript",     "Invia comandi via IPC bridge.")
Component_Ext(sqlite_db, "SQLite Database",  "SQLite3 + sqlite-vss",    "Tabelle virtuali VSS per vettori semantici.")

Container_Boundary(main, "Main Process – Electron") {

    ' ── Driving Adapter ─────────────────────────────────────
    Component(ai_ipc, "AI IPC Adapter", "Node.js, TypeScript", "Canali: ai:init, ai:state, ai:search, ai:generate-embedding, ai:reindex-all, ai:clear")

    ' ── Use Cases ────────────────────────────────────────────
    Component(uc_semantic,   "SearchSemantic",             "Node.js, TypeScript", "Ricerca semantica via AI (similarità vettoriale).")
    Component(uc_reindex,    "GenerateSemanticEmbeddings", "Node.js, TypeScript", "Re-indicizza tutti i documenti generando nuovi vettori.")

    ' ── Ports ────────────────────────────────────────────────
    Component(port_embedding, "WordEmbeddingPort", "TypeScript Interface", "<<Port>> generateEmbedding(text: string): Promise<Vector>.")

    ' ── Repositories ─────────────────────────────────────────
    Component(repo_vector,    "VectorRepository",   "TypeScript Interface", "<<Repository>> save(docId, vector), search(queryVector, limit), getAll(), clear().")
    Component(repo_documento, "DocumentoRepository","TypeScript Interface", "<<Repository>> findById(), findByAip(). Usato per caricare documenti da re-indicizzare.")

    ' ── Driven Adapters ──────────────────────────────────────
    Component(adapt_embedding,        "TransformersJSEmbeddingAdapter",   "ONNX Runtime, TypeScript", "Implementa WordEmbeddingPort. @xenova/transformers con modello paraphrase-multilingual-MiniLM-L12-v2.")
    Component(adapt_vector,           "SQLiteVectorRepository",           "better-sqlite3 + sqlite-vss", "Implementa VectorRepository. Fallback BLOB se sqlite-vss non disponibile.")
    Component(adapt_sqlite_documento, "SQLiteDocumentoRepository",        "better-sqlite3", "Implementa DocumentoRepository.")
}

' ── Renderer → IPC ───────────────────────────────────────────
Rel_D(renderer, ai_ipc, "ai:*", "Electron IPC")

' ── IPC → Use Cases ──────────────────────────────────────────
Rel_D(ai_ipc, uc_semantic, "ai:search")
Rel_R(ai_ipc, uc_reindex,  "ai:reindex-all / ai:init")

' ── SearchSemantic → Port & Repository ───────────────────────
Rel_D(uc_semantic, port_embedding, "Genera embedding query")
Rel_R(uc_semantic, repo_vector,    "Ricerca per similarità")

' ── GenerateSemanticEmbeddings → Port & Repositories ─────────
Rel_D(uc_reindex, port_embedding, "Genera embedding per documento")
Rel_R(uc_reindex, repo_documento, "Carica documenti")
Rel_R(uc_reindex, repo_vector,    "Persiste vettori")

' ── Ports & Repositories → Adapters ─────────────────────────
Rel_D(port_embedding, adapt_embedding,        "impl.")
Rel_D(repo_vector,    adapt_vector,           "impl.")
Rel_D(repo_documento, adapt_sqlite_documento, "impl.")

' ── Adapters → Sistemi Esterni ───────────────────────────────
Rel_D(adapt_vector,           sqlite_db, "CRUD vettoriale (VSS)")
Rel_D(adapt_sqlite_documento, sqlite_db, "CRUD")

@enduml
