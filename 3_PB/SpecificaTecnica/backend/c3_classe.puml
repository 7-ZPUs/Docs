@startuml Component Diagram – ClasseDocumentale IPC
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
title Component Diagram – ClasseDocumentale IPC (classe:get-by-id, classe:search, classe:get-by-status, classe:check-integrity)

LAYOUT_TOP_DOWN()
skinparam linetype ortho
skinparam shadowing false
skinparam wrapWidth 200
skinparam nodesep 60
skinparam ranksep 60

' ══════════════════════════════════════════════════════════════
'  SISTEMI ESTERNI
' ══════════════════════════════════════════════════════════════

Component_Ext(renderer,   "Renderer Process", "Angular, TypeScript",  "Invia comandi via IPC bridge.")
Component_Ext(sqlite_db,  "SQLite Database",  "SQLite3",              "Tabelle relazionali metadati.")
Component_Ext(filesystem, "File System",      "OS File System",       "Pacchetto DIP su disco.")

Container_Boundary(main, "Main Process – Electron") {

    ' ── Driving Adapter ─────────────────────────────────────
    Component(classe_ipc, "ClasseDocumentale IPC Adapter", "Node.js, TypeScript", "Canali: classe:get-by-id, classe:search, classe:get-by-status, classe:check-integrity")

    ' ── Use Cases ────────────────────────────────────────────
    Component(uc_get_classe,       "GetClasseDocumentaleByIdUC",       "Node.js, TypeScript", "Recupera una classe documentale per ID.")
    Component(uc_search_classi,    "SearchClassiDocumentaliUC",        "Node.js, TypeScript", "Ricerca classi documentali per metadati con filtri AND.")
    Component(uc_status_classi,    "GetClassiDocumentaliByStatusUC",   "Node.js, TypeScript", "Filtra classi per stato di integrità.")
    Component(uc_integrity_classe, "CheckClasseDocumentaleIntegrityUC","Node.js, TypeScript", "Calcola SHA256 della classe documentale e confronta con hash atteso.")

    ' ── Ports ────────────────────────────────────────────────
    Component(port_reader, "PackageReaderPort", "TypeScript Interface", "<<Port>> readFileBytes(), getDocumentMetadata().")

    ' ── Repository ───────────────────────────────────────────

    ' ── Driven Adapters ──────────────────────────────────────
    Component(adapt_sqlite_classe, "ClasseDocumentaleRepository", "better-sqlite3")
}

' ── Renderer → IPC ───────────────────────────────────────────
Rel_D(renderer, classe_ipc, "classe:*", "Electron IPC")

' ── IPC → Use Cases ──────────────────────────────────────────
Rel_D(classe_ipc, uc_get_classe,       "classe:get-by-id")
Rel_R(classe_ipc, uc_search_classi,    "classe:search")
Rel_R(classe_ipc, uc_status_classi,    "classe:get-by-status")
Rel_R(classe_ipc, uc_integrity_classe, "classe:check-integrity")

' ── Use Cases → Repository / Port ────────────────────────────
Rel_D(uc_get_classe,       adapt_sqlite_classe,  "Legge classe per ID")
Rel_D(uc_search_classi,    adapt_sqlite_classe,  "Legge classi con filtri")
Rel_D(uc_status_classi,    adapt_sqlite_classe,  "Filtra per stato integrità")
Rel_D(uc_integrity_classe, adapt_sqlite_classe,  "Legge hash atteso")
Rel_R(uc_integrity_classe, port_reader,  "Legge file per calcolo hash")

' ── Adapters → Sistemi Esterni ───────────────────────────────
Rel_D(adapt_sqlite_classe, sqlite_db,  "Read/Write")
Rel_D(port_reader,filesystem, "Lettura DIP")

@enduml
