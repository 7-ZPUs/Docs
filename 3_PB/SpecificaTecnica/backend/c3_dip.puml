@startuml Component Diagram – DIP IPC
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
title Component Diagram – DIP IPC\n(dip:select-directory, dip:index, dip:get-tree, dip:check-integrity)

LAYOUT_TOP_DOWN()
skinparam linetype ortho
skinparam shadowing false
skinparam wrapWidth 200
skinparam nodesep 60
skinparam ranksep 60

' ══════════════════════════════════════════════════════════════
'  SISTEMI ESTERNI
' ══════════════════════════════════════════════════════════════

Component_Ext(renderer,   "Renderer Process", "Angular, TypeScript",  "Invia comandi via IPC bridge.")
Component_Ext(sqlite_db,  "SQLite Database",  "SQLite3 + sqlite-vss", "Tabelle relazionali e tabelle virtuali VSS.")
Component_Ext(filesystem, "File System",      "OS File System",       "Pacchetto DIP su disco.")

Container_Boundary(main, "Main Process – Electron") {

    ' ── Driving Adapter ─────────────────────────────────────
    Component(dip_ipc, "DIP IPC Adapter", "Node.js, TypeScript", "Canali: dip:select-directory, dip:index, dip:get-tree, dip:check-integrity")

    ' ── Use Cases ────────────────────────────────────────────
    Component(uc_index,         "IndexDIP",           "Node.js, TypeScript","Legge DiPIndex.xml, parsa struttura, estrae metadati/file in DB e genera vettori semantici.")
    Component(uc_integrity_dip, "CheckDIPIntegrity",  "Node.js, TypeScript","Calcola SHA256 del DIP e confronta con hash atteso.")

    ' ── Ports ────────────────────────────────────────────────
    Component(port_reader,    "PackageReaderPort",  "TypeScript Interface","<<Port>> getDipIndex(), getPindexByUuid(), getDocumentMetadata(), readFileBytes().")
    Component(port_embedding, "WordEmbeddingPort",  "TypeScript Interface","<<Port>> generateEmbedding(text): Promise<Vector>.")

    ' ── Repositories ─────────────────────────────────────────
    Component(repo_dip,       "DipRepository",                "TypeScript Interface","<<Repository>> get(), create(), list(), delete().")
    Component(repo_classe,    "ClasseDocumentaleRepository",  "TypeScript Interface","<<Repository>> get(), create(), list(), delete(), search().")
    Component(repo_processo,  "ProcessoRepository",           "TypeScript Interface","<<Repository>> get(), create(), list(), delete(), search().")
    Component(repo_documento, "DocumentoRepository",          "TypeScript Interface","<<Repository>> get(), create(), list(), delete(), search().")
    Component(repo_file,      "FileRepository",               "TypeScript Interface","<<Repository>> get(), create(), list(), delete().")
    Component(repo_vector,    "VectorRepository",             "TypeScript Interface","<<Repository>> save(), search(), getAll(), clear().")

    ' ── Driven Adapters ──────────────────────────────────────
    Component(adapt_sqlite_dip,       "SQLiteDipRepository",               "better-sqlite3", "Implementa DipRepository.")
    Component(adapt_sqlite_classe,    "SQLiteClasseDocumentaleRepository", "better-sqlite3", "Implementa ClasseDocumentaleRepository.")
    Component(adapt_sqlite_processo,  "SQLiteProcessoRepository",          "better-sqlite3", "Implementa ProcessoRepository.")
    Component(adapt_sqlite_documento, "SQLiteDocumentoRepository",         "better-sqlite3", "Implementa DocumentoRepository.")
    Component(adapt_sqlite_file,      "SQLiteFileRepository",              "better-sqlite3", "Implementa FileRepository.")
        Component(adapt_vector,           "SQLiteVectorRepository",            "better-sqlite3 + sqlite-vss", "Implementa VectorRepository. Fallback BLOB se sqlite-vss non disponibile.")
        Component(adapt_embedding,        "TransformersJSEmbeddingAdapter",   "ONNX Runtime", "Implementa WordEmbeddingPort. Modello paraphrase-multilingual-MiniLM-L12-v2.")
        Component(adapt_reader,           "FileSystemPackageReaderAdapter",   "Node.js fs", "Implementa PackageReaderPort.")
}

' ── Renderer → IPC ───────────────────────────────────────────
Rel_D(renderer, dip_ipc, "dip:*", "Electron IPC")

' ── IPC → Use Cases ──────────────────────────────────────────
Rel_D(dip_ipc, uc_index,         "dip:index / dip:get-tree")
Rel_R(dip_ipc, uc_integrity_dip, "dip:check-integrity")

' ── IndexDIP → Ports & Repositories ─────────────────────────
Rel_D(uc_index, port_reader,    "Legge struttura DIP")
Rel_R(uc_index, port_embedding, "Genera embeddings")
Rel_D(uc_index, repo_dip,       "Persiste DIP")
Rel_R(uc_index, repo_classe,    "Persiste classi documentali")
Rel_R(uc_index, repo_processo,  "Persiste processi")
Rel_R(uc_index, repo_documento, "Persiste documenti")
Rel_R(uc_index, repo_file,      "Persiste file")
Rel_R(uc_index, repo_vector,    "Persiste vettori semantici")

' ── CheckDIPIntegrity → Ports & Repositories ─────────────────
Rel_D(uc_integrity_dip, repo_dip,    "Legge hash atteso")
Rel_D(uc_integrity_dip, port_reader, "Legge file per calcolo hash")

' ── Repositories → Adapters ──────────────────────────────────
Rel_D(repo_dip,       adapt_sqlite_dip,       "impl.")
Rel_D(repo_classe,    adapt_sqlite_classe,    "impl.")
Rel_D(repo_processo,  adapt_sqlite_processo,  "impl.")
Rel_D(repo_documento, adapt_sqlite_documento, "impl.")
Rel_D(repo_file,      adapt_sqlite_file,      "impl.")
Rel_D(repo_vector,    adapt_vector,           "impl.")

' ── Ports → Adapters ─────────────────────────────────────────
Rel_D(port_embedding, adapt_embedding, "impl.")
Rel_D(port_reader,    adapt_reader,    "impl.")

' ── Adapters → Sistemi Esterni ───────────────────────────────
Rel_D(adapt_sqlite_dip,       sqlite_db,  "CRUD")
Rel_D(adapt_sqlite_classe,    sqlite_db,  "CRUD")
Rel_D(adapt_sqlite_processo,  sqlite_db,  "CRUD")
Rel_D(adapt_sqlite_documento, sqlite_db,  "CRUD")
Rel_D(adapt_sqlite_file,      sqlite_db,  "CRUD")
Rel_D(adapt_vector,           sqlite_db,  "CRUD vettoriale")
Rel_D(adapt_reader,           filesystem, "Lettura DIP")

@enduml
