@startuml Component Diagram – Electron Main Process (Architettura Esagonale)
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
title Component Diagram – Electron Main Process\n(Architettura Esagonale)

LAYOUT_TOP_DOWN()
skinparam linetype ortho

' ══════════════════════════════════════════════════════════════
'  SISTEMI ESTERNI
' ══════════════════════════════════════════════════════════════

Component_Ext(renderer,   "Renderer Process",   "Angular, TypeScript",     "Interfaccia utente che invia comandi e riceve risposte via IPC bridge.")
Component_Ext(sqlite_db,  "SQLite Database",     "SQLite3 + sqlite-vss",    "File DB unico: tabelle relazionali (metadati) e tabelle virtuali VSS (vettori).")
Component_Ext(filesystem, "File System Locale",  "OS File System",          "Pacchetto DIP su disco e destinazione file esportati.")
Component_Ext(printer_hw, "Stampante",           "OS Print API",            "Dispositivo di output per la stampa.")

Container_Boundary(main, "Main Process – Electron") {

    ' ══════════════════════════════════════════════════════════
    '  DRIVING ADAPTERS — IPC Adapters
    '  (core/infrastructure/ipc)
    ' ══════════════════════════════════════════════════════════

    Component(dip_ipc,       "DIP IPC Adapter",               "Node.js, TypeScript", "Canali: dip:get-tree-DIP, dip:check-integrity.\nRiceve dal Renderer le richieste relative al DIP.")
    Component(classe_ipc,    "ClasseDocumentale IPC Adapter",  "Node.js, TypeScript", "Canali: classe:get-by-id, classe:search,\nclasse:get-by-status, classe:check-integrity.")
    Component(processo_ipc,  "Processo IPC Adapter",           "Node.js, TypeScript", "Canali: processo:get-by-id, processo:search,\nprocesso:get-by-status, processo:check-integrity.")
    Component(documento_ipc, "Documento IPC Adapter",          "Node.js, TypeScript", "Canali: documento:get-by-id, documento:search,\ndocumento:get-metadata.")
    Component(file_ipc,      "File IPC Adapter",               "Node.js, TypeScript", "Canali: file:get-by-id, file:get-by-document,\nfile:get-path, file:get-metadata,\nfile:open-external, file:open-in-window,\nfile:print, file:download,\nfile:check-integrity, file:get-integrity-status.")
    Component(ai_ipc,        "AI IPC Adapter",                 "Node.js, TypeScript", "Canali: ai:state, ai:search.")
    Component(search_ipc,    "Search IPC Adapter",             "Node.js, TypeScript", "Canale: search:metadata.\nRicerca trasversale per metadati con filtri AND.")

    note as ipc_note
      OCP: ogni dominio registra il proprio gestore IPC.
      Aggiungere una feature non modifica Adapter esistenti.
    end note

    ' ══════════════════════════════════════════════════════════
    '  APPLICATION CORE — Use Cases
    '  (core/application/use-cases)
    ' ══════════════════════════════════════════════════════════

    Component(uc_index,              "IndexDIP",                        "Node.js, TypeScript", "Legge DiPIndex.xml, parsa struttura, estrae\nmetadati/file in DB e genera vettori semantici.")

    Component(uc_search_classi,      "SearchClassiDocumentali",         "Node.js, TypeScript", "Ricerca classi documentali\nper metadati con filtri AND.")
    Component(uc_search_processi,    "SearchProcessi",                  "Node.js, TypeScript", "Ricerca processi\nper metadati con filtri AND.")
    Component(uc_search_documenti,   "SearchDocumenti",                 "Node.js, TypeScript", "Ricerca documenti\nper metadati con filtri AND.")

    Component(uc_semantic,           "SearchSemantic",                  "Node.js, TypeScript", "Ricerca semantica via AI\n(similarità vettoriale).")

    Component(uc_get_classe,         "GetClasseDocumentaleById",        "Node.js, TypeScript", "Recupero classe documentale\nper chiave primaria.")
    Component(uc_get_processo,       "GetProcessoById",                 "Node.js, TypeScript", "Recupero processo\nper chiave primaria.")
    Component(uc_get_documento,      "GetDocumentoById",                "Node.js, TypeScript", "Recupero documento\nper chiave primaria.")
    Component(uc_get_file,           "GetFileById",                     "Node.js, TypeScript", "Recupero file\nper chiave primaria.")

    Component(uc_status_classi,      "GetClassiDocumentaliByStatus",    "Node.js, TypeScript", "Filtraggio classi documentali\nper stato di integrità.")
    Component(uc_status_processi,    "GetProcessiByStatus",             "Node.js, TypeScript", "Filtraggio processi\nper stato di integrità.")
    Component(uc_status_documenti,   "GetDocumentiByStatus",            "Node.js, TypeScript", "Filtraggio documenti\nper stato di integrità.")
    Component(uc_status_file,        "GetFilesByStatus",                "Node.js, TypeScript", "Filtraggio file\nper stato di integrità.")

    Component(uc_integrity_dip,      "CheckDIPIntegrity",               "Node.js, TypeScript", "Calcola SHA256 del DIP\ne confronta con hash atteso.")
    Component(uc_integrity_classe,   "CheckClasseDocumentaleIntegrity", "Node.js, TypeScript", "Calcola SHA256 della classe documentale\ne confronta con hash atteso.")
    Component(uc_integrity_processo, "CheckProcessoIntegrity",          "Node.js, TypeScript", "Calcola SHA256 del processo\ne confronta con hash atteso.")
    Component(uc_integrity_file,     "CheckFileIntegrity",              "Node.js, TypeScript", "Calcola SHA256 del file\ne confronta con hash atteso.")

    Component(uc_open,               "OpenFile",                        "Node.js, TypeScript", "Apre file con app di sistema\no finestra Electron.")
    Component(uc_export,             "ExportFile",                      "Node.js, TypeScript", "Salva file su disco utente\nnella destinazione scelta.")

    ' ══════════════════════════════════════════════════════════
    '  DOMAIN — Entities & Value Objects
    '  (core/domain/entities)
    ' ══════════════════════════════════════════════════════════

    Component(entities, "Domain Entities & Value Objects", "TypeScript", "Entità: DIP, DocumentClass, AIP, Document, File,\nMetadata, Subject (PF/PG/PAI/PAE/AS/SQ),\nAdministrativeProcedure, Phase,\nDocumentAggregation, ArchivalProcess,\nFileIntegrityCheck, SemanticVector.\nValue Objects: DipUUID, DipPath, AipUUID, AipRoot,\nDocumentClassId, DocumentClassName, DocumentPath,\nFilePath, FileHash, MetaType, HashAlgorithm,\nHashValue, VectorEmbedding(384 dim), DateRange.")

    ' ══════════════════════════════════════════════════════════
    '  PORTS — Outbound Interfaces (Driven Side)
    '  (core/domain/ports)
    ' ══════════════════════════════════════════════════════════

    Component(port_reader,    "PackageReaderPort",  "TypeScript Interface", "<<Port>>\ngetDipIndex(), getPindexByUuid(),\ngetAiPInfoByUuid(), getDocumentMetadata(),\ngetFileContent(), readFileBytes(),\nopenReadStream().")
    Component(port_embedding, "WordEmbeddingPort",  "TypeScript Interface", "<<Port>>\ngenerateEmbedding(text): Promise<Vector>.")
    Component(port_export,    "FileExportPort",     "TypeScript Interface", "<<Port>>\nexportFile(destPath, content),\nopenWriteStream(destPath, source).")
    Component(port_print,     "PrintPort",          "TypeScript Interface", "<<Port>>\nprintFile(buffer),\nprintFileStream(source).")

    ' ══════════════════════════════════════════════════════════
    '  REPOSITORIES — Outbound Interfaces (Driven Side)
    '  (core/domain/repositories)
    ' ══════════════════════════════════════════════════════════

    Component(repo_dip,       "DipRepository",                  "TypeScript Interface", "<<Repository>>\nget(uuid), create(entity),\nlist(), delete(uuid).")
    Component(repo_classe,    "ClasseDocumentaleRepository",    "TypeScript Interface", "<<Repository>>\nget(uuid), create(entity),\nlist(), delete(uuid),\nsearch(filters).")
    Component(repo_processo,  "ProcessoRepository",             "TypeScript Interface", "<<Repository>>\nget(uuid), create(entity),\nlist(), delete(uuid),\nsearch(filters).")
    Component(repo_documento, "DocumentoRepository",            "TypeScript Interface", "<<Repository>>\nget(uuid), create(entity),\nlist(), delete(uuid),\nsearch(filters).")
    Component(repo_file,      "FileRepository",                 "TypeScript Interface", "<<Repository>>\nget(uuid), create(entity),\nlist(), delete(uuid).")

    Component(repo_vector,    "VectorRepository",               "TypeScript Interface", "<<Repository>>\nsave(docId, vector), search(queryVector, limit),\ngetAll(), clear().")

    ' ══════════════════════════════════════════════════════════
    '  DRIVEN ADAPTERS — Infrastructure
    '  (core/infrastructure/adapters)
    ' ══════════════════════════════════════════════════════════

    Component(adapt_sqlite_dip,       "SQLiteDipRepository",                  "better-sqlite3, TypeScript", "Implementa DipRepository.\nPersistenza DIP su SQLite.")
    Component(adapt_sqlite_classe,    "SQLiteClasseDocumentaleRepository",    "better-sqlite3, TypeScript", "Implementa ClasseDocumentaleRepository.\nPersistenza classi documentali su SQLite.")
    Component(adapt_sqlite_processo,  "SQLiteProcessoRepository",             "better-sqlite3, TypeScript", "Implementa ProcessoRepository.\nPersistenza processi su SQLite.")
    Component(adapt_sqlite_documento, "SQLiteDocumentoRepository",            "better-sqlite3, TypeScript", "Implementa DocumentoRepository.\nPersistenza documenti su SQLite.")
    Component(adapt_sqlite_file,      "SQLiteFileRepository",                 "better-sqlite3, TypeScript", "Implementa FileRepository.\nPersistenza file su SQLite.")

    Component(adapt_vector,    "SQLiteVectorRepository",          "better-sqlite3 + sqlite-vss, TypeScript", "Implementa VectorRepository.\nFallback BLOB se sqlite-vss\nnon disponibile.")
    Component(adapt_embedding, "TransformersJSEmbeddingAdapter",  "ONNX Runtime, TypeScript",               "Implementa WordEmbeddingPort.\n@xenova/transformers con modello\nparaphrase-multilingual-MiniLM-L12-v2.")
    Component(adapt_reader,    "FileSystemPackageReaderAdapter",  "Node.js fs, TypeScript",                 "Implementa PackageReaderPort.\nAccesso I/O al pacchetto DIP su disco.")
    Component(adapt_export,    "FileSystemExportAdapter",         "Node.js fs, TypeScript",                 "Implementa FileExportPort.\nSalva file esportati su disco.")
    Component(adapt_printer,   "PrinterPrintPortAdapter",         "Node.js, TypeScript",                    "Implementa PrintPort.\nInvia documenti alla stampante OS.")
}

' ══════════════════════════════════════════════════════════════
'  RELAZIONI: Renderer → IPC Adapters (Driving)
' ══════════════════════════════════════════════════════════════

Rel_D(renderer, dip_ipc,       "dip:*",       "Electron IPC")
Rel_D(renderer, classe_ipc,    "classe:*",    "Electron IPC")
Rel_D(renderer, processo_ipc,  "processo:*",  "Electron IPC")
Rel_D(renderer, documento_ipc, "documento:*", "Electron IPC")
Rel_D(renderer, file_ipc,      "file:*",      "Electron IPC")
Rel_D(renderer, ai_ipc,        "ai:*",        "Electron IPC")
Rel_D(renderer, search_ipc,    "search:*",    "Electron IPC")

' ══════════════════════════════════════════════════════════════
'  RELAZIONI: IPC Adapters → Use Cases
' ══════════════════════════════════════════════════════════════

Rel_D(dip_ipc,       uc_index,              "Avvia importazione DIP")
Rel_D(dip_ipc,       uc_integrity_dip,      "Verifica integrità DIP")

Rel_D(classe_ipc,    uc_get_classe,         "GetClasseDocumentaleById")
Rel_D(classe_ipc,    uc_search_classi,      "SearchClassiDocumentali")
Rel_D(classe_ipc,    uc_status_classi,      "GetClassiDocumentaliByStatus")
Rel_D(classe_ipc,    uc_integrity_classe,   "CheckClasseDocumentaleIntegrity")

Rel_D(processo_ipc,  uc_get_processo,       "GetProcessoById")
Rel_D(processo_ipc,  uc_search_processi,    "SearchProcessi")
Rel_D(processo_ipc,  uc_status_processi,    "GetProcessiByStatus")
Rel_D(processo_ipc,  uc_integrity_processo, "CheckProcessoIntegrity")

Rel_D(documento_ipc, uc_get_documento,      "GetDocumentoById")
Rel_D(documento_ipc, uc_search_documenti,   "SearchDocumenti")

Rel_D(file_ipc,      uc_get_file,           "GetFileById")
Rel_D(file_ipc,      uc_open,               "OpenFile")
Rel_D(file_ipc,      uc_export,             "ExportFile / Download / Print")
Rel_D(file_ipc,      uc_integrity_file,     "CheckFileIntegrity")
Rel_D(file_ipc,      uc_status_file,        "GetFilesByStatus")

Rel_D(ai_ipc,        uc_semantic,           "SearchSemantic")

Rel_D(search_ipc,    uc_search_classi,      "Ricerca trasversale classi")
Rel_D(search_ipc,    uc_search_processi,    "Ricerca trasversale processi")
Rel_D(search_ipc,    uc_search_documenti,   "Ricerca trasversale documenti")

' ══════════════════════════════════════════════════════════════
'  RELAZIONI: Use Cases → Ports & Repositories
' ══════════════════════════════════════════════════════════════

' IndexDIP
Rel_D(uc_index, port_reader,    "Legge struttura DIP",       "PackageReaderPort")
Rel_D(uc_index, port_embedding, "Genera embeddings",         "WordEmbeddingPort")
Rel_D(uc_index, repo_dip,       "Persiste DIP")
Rel_D(uc_index, repo_classe,    "Persiste classi documentali")
Rel_D(uc_index, repo_processo,  "Persiste processi")
Rel_D(uc_index, repo_documento, "Persiste documenti")
Rel_D(uc_index, repo_file,      "Persiste file")
Rel_D(uc_index, repo_vector,    "Persiste vettori semantici")

' Search (testuale)
Rel_D(uc_search_classi,    repo_classe,    "Legge classi con filtri")
Rel_D(uc_search_processi,  repo_processo,  "Legge processi con filtri")
Rel_D(uc_search_documenti, repo_documento, "Legge documenti con filtri")

' SearchSemantic
Rel_D(uc_semantic, port_embedding, "Genera embedding query", "WordEmbeddingPort")
Rel_D(uc_semantic, repo_vector,    "Ricerca per similarità vettoriale")

' GetById
Rel_D(uc_get_classe,    repo_classe,    "Legge classe per ID")
Rel_D(uc_get_processo,  repo_processo,  "Legge processo per ID")
Rel_D(uc_get_documento, repo_documento, "Legge documento per ID")
Rel_D(uc_get_file,      repo_file,      "Legge file per ID")

' GetByStatus
Rel_D(uc_status_classi,    repo_classe,    "Filtra classi per stato integrità")
Rel_D(uc_status_processi,  repo_processo,  "Filtra processi per stato integrità")
Rel_D(uc_status_documenti, repo_documento, "Filtra documenti per stato integrità")
Rel_D(uc_status_file,      repo_file,      "Filtra file per stato integrità")

' CheckIntegrity
Rel_D(uc_integrity_dip,      repo_dip,      "Legge hash atteso DIP")
Rel_D(uc_integrity_dip,      port_reader,   "Legge file per calcolo hash",     "PackageReaderPort")
Rel_D(uc_integrity_classe,   repo_classe,   "Legge hash atteso classe")
Rel_D(uc_integrity_classe,   port_reader,   "Legge file per calcolo hash",     "PackageReaderPort")
Rel_D(uc_integrity_processo, repo_processo, "Legge hash atteso processo")
Rel_D(uc_integrity_processo, port_reader,   "Legge file per calcolo hash",     "PackageReaderPort")
Rel_D(uc_integrity_file,     repo_file,     "Legge hash atteso file")
Rel_D(uc_integrity_file,     port_reader,   "Legge file per calcolo hash",     "PackageReaderPort")

' OpenFile
Rel_D(uc_open, port_reader, "Legge file da aprire", "PackageReaderPort")

' ExportFile
Rel_D(uc_export, port_reader, "Legge file da esportare", "PackageReaderPort")
Rel_D(uc_export, port_export, "Salva su disco",          "FileExportPort")
Rel_D(uc_export, port_print,  "Stampa documento",        "PrintPort")

' ══════════════════════════════════════════════════════════════
'  RELAZIONI: Repositories ← Driven Adapters (implementa)
' ══════════════════════════════════════════════════════════════

Rel_D(repo_dip,       adapt_sqlite_dip,       "Implementato da")
Rel_D(repo_classe,    adapt_sqlite_classe,    "Implementato da")
Rel_D(repo_processo,  adapt_sqlite_processo,  "Implementato da")
Rel_D(repo_documento, adapt_sqlite_documento, "Implementato da")
Rel_D(repo_file,      adapt_sqlite_file,      "Implementato da")
Rel_D(repo_vector,    adapt_vector,           "Implementato da")

' ══════════════════════════════════════════════════════════════
'  RELAZIONI: Ports ← Driven Adapters (implementa)
' ══════════════════════════════════════════════════════════════

Rel_D(port_embedding, adapt_embedding, "Implementato da")
Rel_D(port_reader,    adapt_reader,    "Implementato da")
Rel_D(port_export,    adapt_export,    "Implementato da")
Rel_D(port_print,     adapt_printer,   "Implementato da")

' ══════════════════════════════════════════════════════════════
'  RELAZIONI: Driven Adapters → Sistemi Esterni
' ══════════════════════════════════════════════════════════════

Rel_D(adapt_sqlite_dip,       sqlite_db,   "CRUD relazionale", "better-sqlite3")
Rel_D(adapt_sqlite_classe,    sqlite_db,   "CRUD relazionale", "better-sqlite3")
Rel_D(adapt_sqlite_processo,  sqlite_db,   "CRUD relazionale", "better-sqlite3")
Rel_D(adapt_sqlite_documento, sqlite_db,   "CRUD relazionale", "better-sqlite3")
Rel_D(adapt_sqlite_file,      sqlite_db,   "CRUD relazionale", "better-sqlite3")
Rel_D(adapt_vector,           sqlite_db,   "CRUD vettoriale",  "better-sqlite3 + sqlite-vss")
Rel_D(adapt_reader,           filesystem,  "Lettura pacchetto DIP",    "Node.js fs")
Rel_D(adapt_export,           filesystem,  "Scrittura file esportati", "Node.js fs")
Rel_D(adapt_printer,          printer_hw,  "Invio stampa",             "OS Print API")

@enduml
