@startuml Component Diagram – Angular Renderer (DIPReader) v2
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Component Diagram – Angular Renderer Process (DIPReader) v4\nCopertura UC-1..UC-71 | SOLID + Angular Best Practices\nv4: IpcCacheService · TelemetryService · AccessibilityService · LiveAnnouncerService\n    Mutex Signal (SearchFacade, IntegrityFacade) · SemanticIndexFacade timeout+cancel · WCAG 2.1

'══════════════════════════════════════════════════════════════
' ESTERNI
'══════════════════════════════════════════════════════════════
Person(user, "Utente", "Revisore, archivista o consulente")
System_Ext(ipc, "IPC Dispatcher (Main Process)", "Electron Context Bridge")

'══════════════════════════════════════════════════════════════
' RENDERER ANGULAR
'══════════════════════════════════════════════════════════════
Container_Boundary(renderer, "Renderer Process – Angular 17+  (Standalone Components, Signals)") {

  '──────────────────────────────────────────────────────────
  ' [A] SHELL & ROUTING
  '──────────────────────────────────────────────────────────
  Component(app_shell, "AppShellComponent", "Angular Standalone [Smart – Layout Root]","Root component: toolbar, sidebar navigazione, router-outlet.\nLegge Signal<DipState>.phase da DipFacade:\n  • phase='idle'     → mostra DipLoadingPageComponent (fullscreen)\n  • phase='indexing' → mostra DipLoadingPageComponent con progresso\n  • phase='ready'    → attiva il router-outlet con le rotte normali\nFunge da guard visivo: nessuna rotta è accessibile prima che\nil DIP sia completamente indicizzato.")

  Component(router, "AppRouter", "Angular Router [provideRouter + withComponentInputBinding]","Rotte lazy:\n  /dip           → DipExplorerComponent\n  /search        → SearchPageComponent\n  /document/:id  → DocumentDetailPageComponent\n  /aggregate/:id → AggregateDetailPageComponent\n  /integrity     → IntegrityPageComponent\nTutte le rotte protette da DipReadyGuard:\nnessuna rotta è accessibile se DipState.phase != 'ready'.")

  '──────────────────────────────────────────────────────────
  ' [A2] DIP LOADING & INDEXING SCREEN
  '  Schermata fullscreen mostrata da AppShell mentre
  '  il DIP è in fase di apertura e indicizzazione.
  '  Visibile prima che qualsiasi rotta sia attivabile.
  '──────────────────────────────────────────────────────────
  Component(dip_loading_page, "DipLoadingPageComponent", "Angular Standalone [Smart]\n[Schermata di avvio – fullscreen]","Schermata fullscreen mostrata da AppShellComponent\nmentre DipState.phase è 'idle', 'indexing' o 'error'.\nFasi visualizzate:\n  1. Selezione file DIP\n  2. Decompressione archivio .zip\n  3. Parsing XML metadati AGID\n  4. Indicizzazione relazionale (SQLite)\n  5. [Opzionale] Indicizzazione semantica AI\nGestione errori di fase:\n  • DIP_FILE_NOT_FOUND       → messaggio + bottone 'Seleziona altro file'\n  • DIP_CORRUPT_ARCHIVE      → messaggio + bottone 'Seleziona altro file'\n  • DIP_PARSE_ERROR          → messaggio con fase fallita + dettaglio\n  • DIP_INDEX_ERROR          → messaggio + bottone 'Riprova'\nMostra InlineErrorComponent per errori non fatali;\nper errori fatali (recoverable=false) blocca il flusso.\nDi default: delega la barra di progresso a DipIndexingProgressComponent.")

  Component(dip_indexing_progress, "DipIndexingProgressComponent", "Angular Standalone [Dumb]\n[UC – caricamento DIP]\n[Observer via Signal]","Visualizza il progresso dell'indicizzazione del DIP.\nInput: progress: DipLoadingProgress {\n  phase: LoadingPhase,\n  currentStep: string,\n  stepsCompleted: number,\n  totalSteps: number,\n  percentage: number\n}\nMostra:\n  • Stepper orizzontale con le fasi (decompressione →\n    parsing → indicizzazione relazionale → [semantica])\n  • Barra progresso percentuale\n  • Label 'Indicizzazione documento N di M: <nome>'\n  • Spinner per la fase corrente\nCompletamente Dumb: zero iniezioni di servizi.\nAlimentato da Signal<DipLoadingState> proiettato\nda DipLoadingPageComponent come @Input.")

  Component(dip_ready_guard, "DipReadyGuard", "Angular CanActivateFn\n[Route Guard]","Guard funzionale (Angular 15+ CanActivateFn).\nVerifica che DipFacade.state().phase === 'ready'.\nSe non pronto: reindirizza AppShell a mostrare\nDipLoadingPageComponent invece di attivare la rotta.\nApplicato a tutte le rotte del router.\nDipendenza: DipFacade (via inject()).")

  '──────────────────────────────────────────────────────────
  ' [A3] DIP TREE – Navigazione ad albero
  '  Separato dal modulo DipExplorer perché è un componente
  '  con logica propria (stato expand/collapse, selezione nodo)
  '  riutilizzabile anche nella sidebar di AppShell.
  '──────────────────────────────────────────────────────────
  Component(dip_tree, "DipTreeComponent", "Angular Standalone [Smart – Composite]\n[UC-1, UC-2, UC-3, UC-4, UC-5, UC-6]\n[Lazy Loading + Virtual Scroll]","Albero navigabile a tre livelli con lazy loading e virtual scrolling.\n\n── Lazy Loading ──────────────────────────────────────\nNon carica l'intero albero all'avvio.\nAl primo render chiama DipFacade.loadRootNodes().\nQuando l'utente espande un nodo (evento toggle):\n  1. Controlla se i figli sono già in nodeCache\n  2. Se no → chiama DipFacade.loadChildren(nodeId)\n  3. Aggiorna Signal<expandedIds: Set<nodeId>>\nI nodi in stato 'loading' mostrano uno spinner inline.\n\n── Virtual Scrolling (CDK) ───────────────────────────\nUsa CdkVirtualScrollViewport di @angular/cdk/scrolling.\nMantiene computed<FlatNode[]> che ricalcola l'array\npiatto dei nodi visibili ogni volta che cambiano\nexpandedIds o nodeCache:\n  FlatNode = { node: DipTreeNode, depth: number,\n               hasChildren: boolean, isLoading: boolean }\nSolo i FlatNode nella viewport sono nel DOM.\nItemSize fisso (es. 48px) per performance CDK ottimale.\n\n── Interfaccia ───────────────────────────────────────\n@Input:  rootNodes: DipTreeNode[]\n@Output: nodeSelected: EventEmitter<DipTreeNode>\nNon ricorsivo: delega ogni riga a DipTreeNodeComponent\ntramite *cdkVirtualFor sul FlatNode[] piatto.\nNon conosce Router.")

  Component(dip_tree_node, "DipTreeNodeComponent", "Angular Standalone [Dumb – Non ricorsivo]\n[UC-1, UC-2, UC-3, UC-4, UC-5]\n[Virtual Scroll item]","Riga singola dell'albero virtualizzato. NON ricorsivo.\nAltezza fissa (es. 48px) per CDK itemSize.\n@Input:  flatNode: FlatNode\n         { node, depth, hasChildren, isLoading,\n           childrenError: AppError | null }  ← errore parziale nodo\n@Output: toggle: EventEmitter<nodeId>\n         nodeSelected: EventEmitter<DipTreeNode>\nVisualizza:\n  • padding-left da depth (indentazione visiva)\n  • icona expand/collapse se hasChildren\n  • spinner se isLoading\n  • InlineErrorComponent se childrenError != null\n    (con 'Riprova' se recoverable=true – UC: DIP_CHILDREN_LOAD_ERROR)\n  • nome nodo\n  • VerificationBadgeComponent – UC-4\n  • TimestampLabelComponent    – UC-5\nErrore parziale: fallisce il caricamento figli di UN nodo,\nnon l'intero albero. Gli altri nodi rimangono usabili.")
  '──────────────────────────────────────────────────────────
  Component(ipc_gateway, "IpcGateway", "Angular Service [providedIn:'root']\n[Adapter + ISP]","Unico punto di accesso all'Electron Context Bridge.\nEspone metodi tipizzati per dominio:\n  invoke<T>(channel, payload?, cachePolicy?): Promise<T>\n  on<T>(channel, handler): () => void\n\nCachePolicy (default 'cache-first' per letture):\n  'cache-first'   → legge IpcCacheService; chiama IPC solo su miss\n  'network-first' → chiama IPC, aggiorna cache\n  'no-cache'      → bypass totale (operazioni mutanti obbligatorio)\n\nCanali no-cache obbligatori:\n  verifyDip, verifyClass, verifyProcess, verifyDocument\n  saveFile, saveMultiple, print, exportPdf, download\n  loadDip, writeLog\n\nIsola completamente il resto dell'app da Electron.")

  Component(ipc_error_handler, "IpcErrorHandlerService", "Angular Service [providedIn:'root']\n[SRP – Error Translation]","Traduce errori IPC grezzi nel modello AppError tipizzato:\n\nAppError {\n  code:       ErrorCode        // enum – identifica univocamente l'errore\n  category:   ErrorCategory    // IPC | VALIDATION | DOMAIN | IO | PRINT\n  severity:   ErrorSeverity    // FATAL | ERROR | WARN | INFO\n  recoverable: boolean         // true → mostra 'Riprova'; false → solo 'Chiudi'\n  context?:   string           // es. nome file, nodeId, nome campo\n  detail?:    string           // messaggio tecnico per debug\n}\n\nErrorCode (enum):\n  // DIP loading\n  DIP_FILE_NOT_FOUND, DIP_CORRUPT_ARCHIVE, DIP_PARSE_ERROR,\n  DIP_INDEX_ERROR, DIP_CHILDREN_LOAD_ERROR\n  // Document\n  DOC_NOT_FOUND, DOC_BLOB_LOAD_ERROR, DOC_FORMAT_UNSUPPORTED\n  // Output\n  OUTPUT_IO_ERROR, OUTPUT_SOURCE_FOLDER_FORBIDDEN,\n  OUTPUT_PRINT_ERROR, OUTPUT_FORMAT_NOT_PRINTABLE,\n  OUTPUT_PDF_GENERATION_ERROR, OUTPUT_DOWNLOAD_ERROR\n  // Integrity\n  INTEGRITY_HASH_MISMATCH, INTEGRITY_SIGNATURE_EXPIRED,\n  INTEGRITY_SIGNATURE_INVALID, INTEGRITY_VERIFY_ERROR\n  // Search\n  SEARCH_ENGINE_ERROR\n  // Field-level (opaque per componenti dumb)\n  FIELD_OPTIONAL_ABSENT\n\nEspone:\n  toAppError(ipcError): AppError\n  isFatal(e: AppError): boolean")

  '──────────────────────────────────────────────────────────
  ' [C] CROSS-CUTTING SERVICES
  '──────────────────────────────────────────────────────────
  Component(notification_service, "NotificationService", "Angular Service [providedIn:'root']\n[SRP – Feedback]","Emette toast/snackbar per conferme e messaggi non bloccanti.\nUsato da Facade e OutputToolbar dopo operazioni completate.")

  Component(filter_validator, "FilterValidatorService", "Angular Service [providedIn:'root']\n[SRP – Validation]","Valida i valori dei filtri di ricerca.\nRestituisce ValidationResult con mappa campo→errore.\nUC-10, UC-17, UC-18.")

  ' ── [C2] NUOVI SERVIZI CROSS-CUTTING v4 ──────────────────
  Component(ipc_cache, "IpcCacheService", "Angular Service [providedIn:'root']\n[SRP – Request Deduplication]","Cache in-memory per risposte IPC di sola lettura.\nElimina chiamate IPC ridondanti (es. 3x stessa doc = 1x IPC).\n\nStruttura:\n  entries: Map<cacheKey, { value: T, ts: number, ttl: number }>\n\nAPI:\n  get<T>(key): T | null              – miss automatica se scaduto\n  set<T>(key, value, ttl): void\n  invalidate(key): void\n  invalidatePrefix(prefix): void     – es. 'doc/' dopo reload DIP\n  clear(): void                      – reset all'apertura nuovo DIP\n\nTTL per categoria (ms):\n  getDocumentMetadata  → 300_000 (5 min)\n  getAggregateMetadata → 300_000\n  getAipInfo           → 300_000\n  loadChildren (tree)  → 600_000 (10 min) – migrato da nodeCache\n  getFileBlob          →  60_000 (1 min)  – file grandi, TTL breve\n  search results       →  30_000 (30 sec) – dati più volatili\n\nReset completo (clear()) ad ogni apertura di nuovo DIP.")

  Component(telemetry, "TelemetryService", "Angular Service [providedIn:'root']\n[SRP – Observability]","Log strutturato locale per eventi utente ed errori.\nIn Electron offline: scrive su file rotante via IPC writeLog [no-cache].\n\nTelemetryEvent {\n  type:      EventType  // enum\n  timestamp: number\n  payload:   Record<string, unknown>\n  sessionId: string\n}\n\nEventType:\n  ROUTE_CHANGE, DIP_LOADED, NODE_EXPANDED\n  SEARCH_EXECUTED, SEARCH_LATENCY_MS, SEARCH_RESULT_OPENED\n  FILE_SAVED, FILE_PRINTED, PDF_EXPORTED\n  INTEGRITY_STARTED, INTEGRITY_COMPLETED\n  IPC_ERROR, RENDER_ERROR\n  TREE_RENDER_TIME_MS, BLOB_LOAD_TIME_MS\n\nAPI (tutte fire-and-forget, mai bloccanti, mai rilanciano):\n  trackEvent(type, payload?): void\n  trackError(error: AppError, context?): void\n  trackTiming(label: EventType, ms: number): void\n\nRegola: chiamato DOPO l'aggiornamento del Signal nel Facade.\nNon espone dati all'esterno: log locale only.")

  Component(accessibility_service, "AccessibilityService", "Angular Service [providedIn:'root']\n[SRP – WCAG 2.1 Focus Management]","Gestione centralizzata del focus e navigazione da tastiera.\n\nAPI:\n  trapFocus(container: ElementRef): () => void\n    → focus ciclico dentro dialoghi modali\n    → ritorna untrapper da chiamare alla chiusura\n  restoreFocus(): void\n    → ripristina focus sull'elemento trigger pre-dialogo\n  moveFocusTo(ref: ElementRef | string): void\n  setPageTitle(title: string): void\n    → aggiorna <title> ad ogni cambio rotta (WCAG 2.4.2)\n\nUso:\n  ErrorDialogComponent    → trapFocus + restoreFocus (WCAG 2.1.2)\n  FolderPickerDialog      → trapFocus + restoreFocus\n  AppShellComponent       → setPageTitle ad ogni cambio rotta\n  DipTreeComponent        → gestione frecce su/giù tra nodi\n\nSkip-link 'Vai al contenuto principale' registrato qui (WCAG 2.4.1).")

  Component(live_announcer, "LiveAnnouncerService", "Angular CDK [providedIn:'root']\n[WCAG 2.1 – aria-live]","Wrapper su Angular CDK LiveAnnouncer.\nAnnuncia messaggi dinamici agli screen reader via regione aria-live.\n\nAPI:\n  announce(msg: string, politeness?: 'polite'|'assertive'): void\n\nUsi (politeness='polite' salvo indicato):\n  SearchFacade     → 'Trovati N risultati' – UC-15\n  DipFacade        → 'Indicizzazione X% completata' – ogni 10%\n  DipTreeComponent → 'Espanso: <nome nodo>, N figli'\n  OutputFacade     → 'File salvato con successo'\n  IntegrityFacade  → 'Verifica integrità completata'\n  InlineError      → messaggio errore [assertive] – non bloccante\n  SemanticFacade   → 'Ricerca semantica non disponibile' [assertive]")

  '──────────────────────────────────────────────────────────
  ' [D] SHARED UI – ATOMIC COMPONENTS
  '  Componenti riutilizzabili tra più moduli.
  '  Tutti Dumb: solo @Input/@Output, zero DI di servizi.
  '──────────────────────────────────────────────────────────
  Component(verification_badge, "VerificationBadgeComponent", "Angular Standalone [Dumb – Shared]\n[UC-4] [WCAG 1.4.1, 4.1.2]","Badge: Non Verificato / Valido / Non Valido.\nInput: status: VerificationStatus.\nAccessibilità:\n  role='status', aria-label='Stato verifica: <testo>'\n  Colore NON è unico indicatore: icona + testo sempre presenti.\nRiutilizzato in liste DIP, report integrità e dettaglio documento.")

  Component(timestamp_label, "TimestampLabelComponent", "Angular Standalone [Dumb – Shared]\n[UC-5] [WCAG 1.3.1]","Label marcatura temporale formattata GG/MM/AAAA HH:MM:SS.\nInput: timestamp: string.\nAccessibilità:\n  <time datetime='ISO-8601'> per screen reader e parser semantici.\n  aria-label='Marcatura temporale: <data leggibile>'\nRiutilizzato in liste, dettaglio, report.")

  Component(empty_state, "EmptyStateComponent", "Angular Standalone [Dumb – Shared]\n[UC-6, UC-16] [WCAG 4.1.3]","Messaggio informativo per liste vuote o nessun risultato.\nInput: message: string, icon?: string.\nAccessibilità:\n  role='status', aria-live='polite'\n  Annuncio automatico quando appare nel DOM.\nUC-6 (liste DIP), UC-16 (risultati ricerca).")

  Component(error_dialog, "ErrorDialogComponent", "Angular Standalone [Dumb – Shared]\n[UC-8, UC-21, UC-24, UC-25, UC-36, UC-37]\n[WCAG 2.1.1, 2.1.2, 4.1.2]","Dialogo modale di errore per operazioni bloccanti.\n@Input: error: AppError\nMostra:\n  • Titolo derivato da error.code (localizzato)\n  • Messaggio contestuale (error.context se presente)\n  • Dettaglio tecnico espandibile (error.detail)\n  • Bottone 'Riprova' se error.recoverable === true\n  • Bottone 'Chiudi' sempre presente\nSeverity determina colore header (ERROR=rosso, WARN=giallo).\nAccessibilità:\n  role='alertdialog', aria-modal='true'\n  aria-labelledby → id del titolo dialogo\n  aria-describedby → id del corpo messaggio\n  Focus trap via AccessibilityService.trapFocus() (WCAG 2.1.2)\n  Tasto Esc chiude il dialogo (WCAG 2.1.1)\n  restoreFocus() alla chiusura → ritorna al trigger\nAperto da: OutputFacade (UC-21,24,25,36,37), PreviewPanelComponent (UC-8).")

  Component(inline_error, "InlineErrorComponent", "Angular Standalone [Dumb – Shared]\n[Errori non bloccanti – inline]","Messaggio di errore inline, non modale.\n@Input: error: AppError\nUsi:\n  • Slot 'error' di AsyncStateWrapperComponent\n    (errori di caricamento pagina – recuperabili)\n  • Nodo albero con loadChildren fallito (UC: DIP_CHILDREN_LOAD_ERROR)\n  • Banner errore indicizzazione in DipLoadingPageComponent\nMostra:\n  • Icona severity + messaggio localizzato\n  • Link 'Riprova' se error.recoverable === true\nNon blocca la UI: il resto della pagina rimane usabile.")

  Component(field_error, "FieldErrorComponent", "Angular Standalone [Dumb – Shared]\n[UC-18, UC-10 – Errori di campo]","Messaggio di errore a livello di singolo campo.\n@Input: error: ValidationError | null\nValidationError { field: string, message: string }\nUso: sotto ogni FilterValueInputComponent quando\nil valore ha formato non corretto (UC-18).\nDistinto da AppError: non passa per IpcErrorHandler,\nè prodotto localmente da FilterValidatorService.\nMostra il messaggio inline sotto il campo.")

  Component(optional_absent, "OptionalFieldAbsentComponent", "Angular Standalone [Dumb – Shared]\n[UC-39.3, UC-39.6, UC-39.9, UC-46, UC-47, UC-57.3, UC-71]","Messaggio informativo per campi opzionali assenti nei metadati.\n@Input: message: string, uc?: string\nDistinto da errore: non è un malfunzionamento,\nè un dato legittimamente non presente nel DIP.\nUso: ConservationProcessComponent (UC-39.3, UC-39.6, UC-39.9),\n  DocumentMetadataComponent (note assenti UC-47, conservazione\n  ereditata UC-46), AttachmentsComponent (UC-57.3),\n  CustomMetadataComponent (metadati custom assenti UC-71).\nMotivazione: centralizza il pattern 'campo assente'\nevitando che ogni componente reimplementi il messaggio.")

  '──────────────────────────────────────────────────────────
  ' [E] SHARED UI – ASYNC STATE WRAPPER
  '  Componente trasversale che risolve il problema del
  '  boilerplate loading/error/empty nelle smart pages.
  '  Pattern: Container Component + ng-content projection.
  '──────────────────────────────────────────────────────────
  Component(async_state_wrapper, "AsyncStateWrapperComponent", "Angular Standalone [Dumb – Shared]\n[Cross-cutting – Template Method]","Wrapper generico per stati asincroni IPC.\n@Input:\n  loading: boolean\n  error:   AppError | null    ← tipizzato, non solo string\n  empty:   boolean\nProietta tre named slots via ng-content:\n  <ng-template slot='loading'> → spinner\n  <ng-template slot='error'>   → InlineErrorComponent\n  <ng-template slot='content'> → contenuto reale\nPassa AppError a InlineErrorComponent per\nrendere il messaggio, la severity e il bottone\n'Riprova' (se error.recoverable === true).\nUsato da: DipExplorerComponent, DocumentDetailPageComponent,\n  AggregateDetailPageComponent, IntegrityPageComponent,\n  SearchPageComponent.")

  '──────────────────────────────────────────────────────────
  ' [F] FACADE SERVICES
  '──────────────────────────────────────────────────────────
  Component(dip_facade, "DipFacade", "Angular Service [Injectable]\n[Facade + SRP]","Stato del DIP caricato.\nSignal<DipState>:\n  phase: 'idle'|'indexing'|'ready'|'error'\n  loadingProgress: DipLoadingProgress\n  loadingError:    AppError | null   ← fase fallita + ErrorCode specifico\n  rootNodes: DipTreeNode[]\n  nodeChildrenErrors: Map<nodeId, AppError>  ← errori parziali per nodo\n  nodeCache: Map<nodeId, DipTreeNode[]>\nAPI lazy loading:\n  loadRootNodes()  → AppError(DIP_FILE_NOT_FOUND | DIP_CORRUPT_ARCHIVE\n                              | DIP_PARSE_ERROR | DIP_INDEX_ERROR)\n  loadChildren(id) → AppError(DIP_CHILDREN_LOAD_ERROR) per nodo specifico\nUC-1, UC-2, UC-3, UC-6.")

  Component(search_facade, "SearchFacade", "Angular Service [Injectable]\n[Facade + SRP]","Stato ricerca.\nSignal<SearchState>:\n  query, filters, results, loading\n  error:            AppError | null  ← SEARCH_ENGINE_ERROR\n  validationErrors: Map<field, ValidationError>  ← UC-10, UC-18\n  isSearching:      boolean  ← mutex: blocca submit concorrenti\n\nControllo concorrenza:\n  Ogni nuova ricerca cancella la chiamata IPC precedente\n  tramite AbortController passato a IpcGateway.invoke().\n  Debounce 300ms interno: toObservable(query).pipe(debounceTime(300)).\n  NON delegato a SearchBarComponent.\n  isSearching=true per tutta la durata della chiamata;\n  una seconda submit ignorata silenziosamente se isSearching=true.\n  isSearching resettato in finally: garantito=false anche su SEARCH_ENGINE_ERROR.\n  Se SemanticIndexFacade.status ≠ 'ready' → disabilita\n  automaticamente il canale searchSemantic (degrado graceful).\nUC-9, UC-9.1..9.4, UC-10, UC-15, UC-16.")

  Component(document_facade, "DocumentFacade", "Angular Service [Injectable]\n[Facade + SRP]","Stato dettaglio documento.\nSignal<DocumentDetail | null>, loading\n  error: AppError | null\n    DOC_NOT_FOUND      → 404 del documento\n    DOC_BLOB_LOAD_ERROR → file fisico non leggibile\nUC-42..58, UC-71.")

  Component(aggregate_facade, "AggregateFacade", "Angular Service [Injectable]\n[Facade + SRP]","Stato dettaglio aggregazione.\nSignal<AggregateDetail | null>, loading\n  error: AppError | null  (DOC_NOT_FOUND per aggregazione)\nUC-59..70.")

  Component(integrity_facade, "IntegrityFacade", "Angular Service [Injectable]\n[Facade + SRP]","Avvia verifiche, raccoglie report.\nSignal<IntegrityState>:\n  report, progress, loading\n  systemError:  AppError | null   ← INTEGRITY_VERIFY_ERROR (crash IPC)\n  isVerifying:  boolean           ← mutex: blocca avvio concorrente\n  NOTE: HASH_MISMATCH e SIGNATURE_* NON sono AppError —\n        sono IntegrityResult nel report (errori di dominio,\n        non malfunzionamenti); gestiti da doc_integrity_report.\n\nControllo concorrenza:\n  isVerifying=true per tutta la durata della verifica IPC.\n  Secondo verifyRequested ignorato mentre isVerifying=true.\n  IntegrityTriggerComponent disabilita i bottoni via\n  @Input disabledWhileVerifying derivato dal Signal.\n  verifyDocument (UC-29 da DocumentActions): stessa regola;\n  mostra tooltip 'Verifica già in corso' se isVerifying=true.\nUC-26..33.")

  Component(output_facade, "OutputFacade", "Angular Service [Injectable]\n[Facade + SRP]","Coordina operazioni di output.\nPer ogni operazione restituisce Result<void, AppError>:\n  OUTPUT_IO_ERROR                 → UC-21, UC-36\n  OUTPUT_SOURCE_FOLDER_FORBIDDEN  → UC-35 (blocco cartella sorgente)\n  OUTPUT_PRINT_ERROR              → UC-24\n  OUTPUT_FORMAT_NOT_PRINTABLE     → UC-25\n  OUTPUT_PDF_GENERATION_ERROR     → UC-37\n  OUTPUT_DOWNLOAD_ERROR           → UC-36\nApre ErrorDialogComponent con AppError tipizzato.\nUC-19, UC-20, UC-22, UC-23, UC-34, UC-35.")

  Component(semantic_facade, "SemanticIndexFacade", "Angular Service [Injectable]\n[Facade – Opzionale]","Stato indicizzazione semantica AI.\nSignal<SemanticIndexState>:\n  status: 'idle'|'indexing'|'ready'|'error'|'timeout'|'cancelled'\n  progress: number  (0..100)\n  error: AppError | null\n\nPolicy cache: SEMPRE no-cache.\n  getIndexingStatus → no-cache (stato volatile in streaming)\n  semantic:cancel   → no-cache (operazione mutante)\n  Nessun canale di SemanticFacade usa IpcCacheService.\n\nTimeout e cancellazione:\n  Timeout configurabile (default 120s) avviato con l'indicizzazione.\n  Se scade → status='timeout'; app degrada a sola ricerca full-text.\n  cancel(): void\n    → invia IPC 'semantic:cancel' [no-cache] al Main Process\n    → imposta status='cancelled' immediatamente nel Signal\n    → LiveAnnouncer: 'Ricerca semantica non disponibile' [assertive]\n\n'timeout' e 'cancelled' NON sono AppError:\n  non sono crash IPC, non passano per IpcErrorHandlerService.\n  SemanticIndexStatusComponent mostra banner informativo.\n  SearchFacade disabilita searchSemantic automaticamente\n  (degrado graceful – ricerca full-text rimane integra).\n\nDipLoadingPageComponent espone bottone 'Salta indicizzazione AI'\nche chiama cancel() durante la fase 5 [Opzionale].\nUC-9.2 (opzionale), UC-11.")

  '──────────────────────────────────────────────────────────
  ' [G] MODULE: DIP EXPLORER
  '──────────────────────────────────────────────────────────
  Component(dip_explorer, "DipExplorerComponent", "Angular Standalone [Smart]\nRoute: /dip","Pagina di navigazione struttura DIP.\nLegge Signal<DipState>.rootNodes da DipFacade.\nOspita DipTreeComponent come unica vista della struttura.\nUC-1 (classi), UC-2 (processi), UC-3 (documenti) sono\nsoddisfatti dai nodi dell'albero ai rispettivi livelli.\nGestisce l'@Output nodeSelected di DipTreeComponent:\n  • tipo 'document'   → router.navigate(['/document', id])\n  • tipo 'aggregate'  → router.navigate(['/aggregate', id])\nAvvolge con AsyncStateWrapperComponent.")

  '──────────────────────────────────────────────────────────
  ' [H] MODULE: DOCUMENT DETAIL
