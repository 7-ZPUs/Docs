'══════════════════════════════════════════════════════════════
' RELAZIONI
'══════════════════════════════════════════════════════════════

' ── Utente → Shell ────────────────────────────────────────
Rel(user, app_shell, "Interagisce con la UI", "Mouse / Tastiera")

' ── Shell → Router ────────────────────────────────────────
Rel(app_shell, router,            "attiva rotte quando phase='ready'")
Rel(app_shell, dip_loading_page,  "mostra quando phase='idle'|'indexing'")
Rel(app_shell, dip_tree,          "sidebar: @Input rootNodes – navigazione persistente quando phase='ready'")
Rel(app_shell, dip_facade,        "legge Signal<DipState>.phase per switch visivo")
Rel(app_shell, router,            "DipTree sidebar: @Output nodeSelected → router.navigate(['/document'|'/aggregate', id])")
Rel(dip_tree,  dip_facade,        "loadChildren(nodeId) + legge nodeCache\n(Signal condiviso – stesso stato di DipExplorerComponent)")

' ── DipReadyGuard ─────────────────────────────────────────
Rel(dip_ready_guard, dip_facade,  "inject() DipFacade – verifica phase==='ready'")
Rel(router, dip_ready_guard,      "CanActivateFn su tutte le rotte")
Rel(router, dip_explorer,         "Lazy /dip [guard: DipReadyGuard]")
Rel(router, search_page,          "Lazy /search [guard: DipReadyGuard]")
Rel(router, document_page,        "Lazy /document/:id [guard: DipReadyGuard]")
Rel(router, aggregate_page,       "Lazy /aggregate/:id [guard: DipReadyGuard]")
Rel(router, integrity_page,       "Lazy /integrity [guard: DipReadyGuard]")

' ── DipLoadingPage ────────────────────────────────────────
Rel(dip_loading_page, dip_facade,            "legge Signal<DipLoadingState>")
Rel(dip_loading_page, dip_indexing_progress, "@Input progress: DipLoadingProgress")
Rel(dip_loading_page, inline_error,          "@Input error: AppError – errori di fase DIP\n(DIP_CORRUPT_ARCHIVE, DIP_PARSE_ERROR, DIP_INDEX_ERROR)")
' DipFacade aggiorna il Signal; DipLoadingPageComponent (Smart) lo legge
' e proietta via @Input a DipIndexingProgressComponent (Dumb) — nessuna freccia diretta Facade→Dumb

' ── IPC Gateway → Main ────────────────────────────────────
Rel(ipc_gateway, ipc, "invoke / on", "Electron contextBridge")
Rel(ipc_gateway, ipc_error_handler, "errori IPC → IpcAppError")
Rel(ipc_gateway, ipc_cache, "get(key) prima di invoke [cache-first];\nset(key,val,ttl) dopo risposta IPC")

' ── Facade → IPC Gateway ──────────────────────────────────
Rel(dip_facade,       ipc_gateway, "loadDip [no-cache], getClasses, getProcesses, getDocuments")
Rel(search_facade,    ipc_gateway, "search, searchAdvanced [AbortController per cancel],\nsearchSemantic [no-cache se status≠ready]")
Rel(document_facade,  ipc_gateway, "getDocumentMetadata [cache-first],\ngetFileBlob [cache-first, TTL 60s], getAipInfo [cache-first]")
Rel(aggregate_facade, ipc_gateway, "getAggregateMetadata [cache-first]")
Rel(integrity_facade, ipc_gateway, "verifyDip, verifyClass, verifyProcess,\nverifyDocument [tutti no-cache]")
Rel(output_facade,    ipc_gateway, "saveFile, saveMultiple, print,\nexportPdf, download [tutti no-cache]")
Rel(semantic_facade,  ipc_gateway, "getIndexingStatus, semantic:cancel [no-cache]")

' ── Facade → Cross-cutting ────────────────────────────────
Rel(dip_facade,       notification_service, "feedback caricamento DIP completato")
Rel(output_facade,    notification_service, "conferma operazione output completata")
Rel(integrity_facade, notification_service, "conferma verifica integrità completata")
Rel(semantic_facade,  notification_service, "conferma indicizzazione semantica completata")
Rel(search_facade,    filter_validator,     "pre-validazione filtri UC-10")
Rel(output_facade,    ipc_error_handler,    "Result<void,AppError> → ErrorDialog")
Rel(integrity_facade, ipc_error_handler,    "INTEGRITY_VERIFY_ERROR → InlineError in IntegrityPage")
Rel(dip_facade,       ipc_error_handler,    "DIP_* errors → AppError nel Signal<DipState>")
Rel(document_facade,  ipc_error_handler,    "DOC_* errors → AppError nel Signal<DocumentDetail>")
Rel(aggregate_facade, ipc_error_handler,    "AppError nel Signal<AggregateDetail>")

' ── TelemetryService ──────────────────────────────────────
Rel(dip_facade,       telemetry, "trackEvent(DIP_LOADED)\ntrackEvent(NODE_EXPANDED)\ntrackError(AppError)")
Rel(search_facade,    telemetry, "trackEvent(SEARCH_EXECUTED)\ntrackTiming(SEARCH_LATENCY_MS)\ntrackError(AppError)")
Rel(document_facade,  telemetry, "trackEvent(SEARCH_RESULT_OPENED)\ntrackTiming(BLOB_LOAD_TIME_MS)")
Rel(output_facade,    telemetry, "trackEvent(FILE_SAVED|PRINTED|PDF_EXPORTED)\ntrackError(AppError)")
Rel(integrity_facade, telemetry, "trackEvent(INTEGRITY_STARTED|COMPLETED)\ntrackError(AppError)")
Rel(app_shell,        telemetry, "trackEvent(ROUTE_CHANGE) ad ogni NavigationEnd")
Rel(telemetry,        ipc_gateway, "writeLog(entry) [no-cache] → file rotante Electron")

' ── AccessibilityService + LiveAnnouncer ──────────────────
Rel(app_shell,           accessibility_service, "setPageTitle() ad ogni cambio rotta (WCAG 2.4.2)")
Rel(error_dialog,        accessibility_service, "trapFocus() apertura; restoreFocus() chiusura (WCAG 2.1.2)")
Rel(folder_picker_dialog,accessibility_service, "trapFocus() apertura; restoreFocus() chiusura (WCAG 2.1.2)")
Rel(dip_tree,            accessibility_service, "gestione frecce su/giù tra nodi (WCAG 2.1.1)")
Rel(search_facade,       live_announcer, "announce('Trovati N risultati') – UC-15 [polite]")
Rel(dip_facade,          live_announcer, "announce('Indicizzazione X%') ogni 10% [polite]")
Rel(dip_tree,            live_announcer, "announce('Espanso: <nodo>, N figli') [polite]")
Rel(output_facade,       live_announcer, "announce('Operazione completata') [polite]\nannounce(errore) [assertive]")
Rel(integrity_facade,    live_announcer, "announce('Verifica completata') [polite]")
Rel(semantic_facade,     live_announcer, "announce('Ricerca semantica non disponibile') [assertive]\n  su status=timeout|cancelled|error")

' ── [G] DIP EXPLORER ──────────────────────────────────────
' Lazy loading: DipFacade carica solo i nodi radice all'avvio.
' I figli vengono caricati on-demand da DipTreeComponent
' quando l'utente espande un nodo (evento toggle).
' Virtual scroll: DipTreeComponent mantiene FlatNode[] piatto
' e usa CdkVirtualScrollViewport — nessuna ricorsione nel DOM.
'
' Catena di navigazione (nodo foglia → vista documento):
'   DipTreeNodeComponent  @Output nodeSelected
'     → DipTreeComponent  bubble up @Output nodeSelected
'       → DipExplorerComponent  router.navigate
'         → DocumentDetailPageComponent / AggregateDetailPageComponent
Rel(dip_explorer, dip_facade,          "legge Signal<DipState>.rootNodes (solo nodi radice)")
Rel(dip_explorer, async_state_wrapper, "avvolge l'albero [loading, error: AppError – UC-6]")
Rel(async_state_wrapper, inline_error, "slot 'error' → @Input error: AppError")
Rel(dip_explorer, dip_tree,            "@Input rootNodes: DipTreeNode[] – UC-1, UC-2, UC-3")
Rel(dip_explorer, router,              "router.navigate(['/document'|'/aggregate', id])\nsu @Output nodeSelected da DipTreeComponent")
Rel(dip_tree,     dip_facade,          "loadChildren(nodeId) on-demand al toggle\nlegge nodeChildrenErrors per errori parziali")
Rel(dip_tree,     dip_tree_node,       "*cdkVirtualFor su FlatNode[] – solo nodi in viewport nel DOM")
Rel(dip_tree_node, verification_badge, "@Input status – UC-4")
Rel(dip_tree_node, timestamp_label,    "@Input timestamp – UC-5")
Rel(dip_tree_node, inline_error,       "@Input error: AppError (DIP_CHILDREN_LOAD_ERROR parziale)")
Rel(dip_tree,     empty_state,         "fallback se rootNodes vuoto – UC-6")

' ── [H] DOCUMENT DETAIL ───────────────────────────────────
Rel(document_page, document_facade,     "legge Signal<DocumentDetail>")
Rel(document_page, async_state_wrapper, "avvolge il contenuto [loading, error]")
Rel(document_page, document_viewer,     "@Input documentId, mimeType, fileName – UC-7")
Rel(document_page, metadata_panel,      "@Input documentDetail – UC-42..71")

' H1: DocumentViewer
Rel(document_viewer, preview_panel,      "@Input src: Uint8Array, loading, error – UC-7 (Dumb)")
Rel(document_viewer, document_actions,   "delega azioni @Input documentId, mimeType – UC-19,22,29,34,35")
Rel(document_viewer, document_facade,    "getFileBlob(documentId) → src passato a PreviewPanel [cache-first TTL 60s]")
Rel(document_viewer, error_dialog,       "AppError(DOC_FORMAT_UNSUPPORTED|DOC_BLOB_LOAD_ERROR) – UC-8")
Rel(preview_panel,   preview_renderer,   "@Input src, mimeType – rendering puro UC-7")
Rel(preview_renderer, preview_panel,     "@Output unsupportedFormat → UC-8 (gestito da DocumentViewer)")

