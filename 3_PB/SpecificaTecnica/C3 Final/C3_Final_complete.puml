  Component(subject_detail_form, "SubjectDetailFormComponent", "Angular Standalone [Dumb]\n[UC-13.3.1..7]\n[Strategy per SubjectType]", "Form dettagli soggetto dinamico.\n@Input subjectType → campi specifici (PAI, PAE, AS, PG, PF, RUP, SW).")

  Component(filter_value_input, "FilterValueInputComponent", "Angular Standalone [Dumb]\n[UC-17, UC-18]","Input generico valore filtro con validazione inline.\nUsa FieldErrorComponent per mostrare errori di formato.\n@Input:  value, fieldType: FilterFieldType\n@Output: valueChanged, validationError: ValidationError | null\nValidazione locale sincrona (formato data, formato numerico, ecc.).\nUC-18: FieldErrorComponent appare sotto il campo in tempo reale.")

  Component(search_results, "SearchResultsComponent", "Angular Standalone [Dumb]\n[UC-15, UC-16]","Lista risultati: nome e tipo per elemento.\n@Input:  results: SearchResult[]\n@Output: resultSelected: EventEmitter<string>  ← emette documentId\nNON istanzia DocumentViewer direttamente.\nDelega la selezione a SearchPageComponent (Smart) che gestisce\nlo stato selectedDocumentId e istanzia DocumentViewerComponent.\nFallback: EmptyStateComponent (UC-16).")

