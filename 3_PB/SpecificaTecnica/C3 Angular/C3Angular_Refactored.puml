@startuml Component Diagram Renderer Process (Simplified - Thin Wrapper Pattern)
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Component Diagram: Renderer Process (Angular UI + IPC Coordination)


Component_Ext(main, "Main Process", "Node.js, TypeScript", "Business logic layer:\n• Search algorithms\n• Indexing & database\n• Verification logic\n• File I/O\n• AI embeddings")

Container_Boundary(renderer, "Renderer Process (Angular)") {

    System_Boundary(layer_1, "1 PRESENTATION (Smart Components)") { 
        Component(nav_bar, "Navigation Bar", "Component", "Route navigation")
        Component(side_bar, "Sidebar", "Component", "DIP tree, document selection")
        Component(workspace_ui, "Workspace UI", "Component", "Import status, progress")
        Component(search_ui, "Search UI", "Component", "Text search interface")
        Component(sema_search_ui, "Semantic Search UI", "Component", "Semantic search interface")
        Component(dip_tree_view, "DIP Tree View", "Component", "Document tree display")
        Component(document_viewer, "Document Viewer", "Component", "Document content display")
        Component(document_actions, "Document Actions", "Component", "Export, print buttons")
        Component(verification_ui, "Verification UI", "Component", "Integrity check display")
        Component(metadata_panel, "Metadata Panel", "Component", "Document metadata display")
    }
    
    System_Boundary(layer_2, "2 STATE MANAGEMENT (RxJS Observables)") {
        Component(nav_state, "Navigation State", "BehaviorSubject<T>", "route$: Current route\nactiveTab$: Active tab")
        Component(import_state, "Import State", "BehaviorSubject<T>", "dipTree$: Document tree\nselectedDocument$: Current selection\nimportStatus$: Load state")
        Component(search_state, "Search State", "BehaviorSubject<T>", "searchResults$: Text results\nsemanticResults$: Semantic results")
    }

    System_Boundary(layer_3, "3 DOMAIN SERVICES (Thin Wrappers - Coordination Only)") {
        Component(nav_service, "Navigation Service", "Service", "SRP: Route coordination.\nManages Router angular.\nUpdates nav_state")
        Component(import_service, "Import Service", "Service", "SRP: DIP loading coordination.\nIPC: Request load -> Main.\nManages: retry, progress.\nUpdates: import_state")
        Component(search_service, "Search Service", "Service", "SRP: Search coordination.\nIPC: Query -> Main.\nLocal validation pre-check.\nUpdates: search_state, cache")
        Component(verification_service, "Verification Service", "Service", "SRP: Verification coordination.\nIPC: Request verify -> Main.\nManages: result display")
        Component(export_service, "Export Service", "Service", "SRP: Export coordination.\nIPC: Request export -> Main.\nManages: format selection")
        Component(metadata_service, "Metadata Service", "Service", "SRP: Metadata coordination.\nIPC: Fetch metadata -> Main.\nManages: caching")
    }

    System_Boundary(layer_4, "4 INFRASTRUCTURE (Essential utilities)") {
        Component(ipc_client, "IPC Client", "Service", "DIP: Context Bridge abstraction.\nType-safe channel communication.\nRequest/response handling")
        Component(error_handler, "Error Handler", "Service", "Error classification & recovery.\nValidation errors.\nNetwork errors.\nUser notification")
        Component(notification_service, "Notification Service", "Service", "User feedback channel.\nToast, snackbar.\nModal dialogs.\nError alerts")
        Component(query_validator, "Query Validator", "Service", "Pre-flight validation.\nSyntax checking.\nFail-fast before IPC.\nReduces latency")
        Component(performance_monitor, "Performance Monitor", "Service", "Operation latency tracking.\nSearch response time.\nImport duration.\nAudit enrichment")
        Component(audit_logger, "Audit & Logging", "Service", "AGID compliance tracking.\nUser operations.\nTimestamps events. -> Main Process")
        Component(router, "Angular Router", "Framework", "Navigation mechanism")
    }
}

' INTERACTIONS & DATA FLOW
Rel(nav_bar, nav_state, "subscribe")
Rel(side_bar, import_state, "subscribe")
Rel(workspace_ui, import_state, "subscribe")
Rel(search_ui, search_state, "subscribe")
Rel(sema_search_ui, search_state, "subscribe")
Rel(dip_tree_view, import_state, "subscribe")
Rel(document_viewer, import_state, "subscribe")
Rel(document_actions, import_state, "subscribe")
Rel(metadata_panel, import_state, "subscribe")

Rel(document_actions, export_service, "call export()")
Rel(search_ui, query_validator, "call validate()")
Rel(sema_search_ui, query_validator, "call validate()")
Rel(nav_bar, nav_service, "call navigate()")

Rel(nav_service, nav_state, "emit updates")
Rel(import_service, import_state, "emit updates")
Rel(search_service, search_state, "emit updates")

Rel(nav_service, router, "use")
Rel(import_service, ipc_client, "IPC call")
Rel(search_service, ipc_client, "IPC call")
Rel(search_service, query_validator, "call validate()")
Rel(verification_service, ipc_client, "IPC call")
Rel(export_service, ipc_client, "IPC call")
Rel(metadata_service, ipc_client, "IPC call")

Rel(error_handler, notification_service, "notify")
Rel(error_handler, audit_logger, "log")
Rel(import_service, error_handler, "report errors")
Rel(search_service, error_handler, "report errors")
Rel(export_service, error_handler, "report errors")
Rel(verification_service, error_handler, "report errors")

Rel(import_service, performance_monitor, "measure latency")
Rel(search_service, performance_monitor, "measure latency")
Rel(export_service, performance_monitor, "measure latency")
Rel(verification_service, performance_monitor, "measure latency")

Rel(performance_monitor, audit_logger, "enrich logs")
Rel(import_service, audit_logger, "log: load, select")
Rel(search_service, audit_logger, "log: text/semantic search")
Rel(export_service, audit_logger, "log: export, print")
Rel(verification_service, audit_logger, "log: verify")

Rel(ipc_client, main, "Electron IPC / Context Bridge")

'note as principles
'  **ARCHITECTURE PRINCIPLES:**
'  
'  Separation of Concerns:
'  - Angular (Renderer): UI rendering, state, coordination
'  - Node.js (Main): Business logic, algorithms, data persistence
'  
'  Service Layer (Thin Wrappers):
'  - NavigationService: Routes via Angular Router
'  - ImportService: Coordinates file loading (IPC -> Main)
'  - SearchService: Coordinates queries (IPC -> Main)
'  - VerificationService: Coordinates verification (IPC -> Main)
'  - ExportService: Coordinates export (IPC -> Main)
'  - MetadataService: Coordinates metadata fetch (IPC -> Main)
'  
'  Data Flow Pattern:
'  Component -> Service -> Query Validator -> IPC Client -> Main Process -> IPC Client -> Service -> State -> Component (render)
'  
'  Key Patterns:
'  - Observer: RxJS BehaviorSubject for state
'  - Adapter: IPC Client abstracts Context Bridge
'  - Facade: Each service wraps IPC complexity
'  - Single Responsibility: Each service = one domain
'  
'  AGID Compliance:
'  - Audit logging all operations with timestamps
'  - Performance metrics for SLA tracking
'  - Error tracking for compliance
'end note
'
@enduml