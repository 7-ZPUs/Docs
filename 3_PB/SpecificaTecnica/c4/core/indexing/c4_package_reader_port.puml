@startuml Class Diagram - Indicizzazione
allowmixing
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 80
skinparam ranksep 70
skinparam shadowing false
skinparam packageStyle rectangle

' --- 1. INFRASTRUTTURA INBOUND ---
package "Infrastructure Layer (Inbound)" #fff2e6 {
    class IndexingIpcAdapter {
        - indexDipUC: IndexDipUC
        + IndexingIpcAdapter(indexDipUC: IndexDipUC)
        + handleIndexDip(event, dipPath: string): Promise<IndexResult>
    }
}

' --- 2. APPLICATION LAYER ---
package "Application Layer" #eaf5ff {
    interface IndexDipUC {
        + execute(dipPath: string): Promise<IndexResult>
    }
    class IndexDipService implements IndexDipUC {
        - reader: IPackageReaderPort
        - documentalClassRepository: IDocumentalClassRepository
        - processRepository: IProcessRepository
        - documentRepository: IDocumentRepository
        - fileRepository: IFileRepository
        + IndexDipService(reader: IPackageReaderPort, documentalClassRepository: IDocumentalClassRepository, processRepository: IProcessRepository, documentRepository: IDocumentRepository, fileRepository: IFileRepository)
        + execute(dipPath: string): Promise<IndexResult>
    }
}

' --- 3. DOMAIN LAYER (Core) ---
package "Domain Layer (Core Business)" #f9f9f9 {

    ' PORTE
    interface IPackageReaderPort {
        + readDip(dipPath: string): Promise<Dip>
        + readDocumentalClasses(dipPath: string): AsyncGenerator<DocumentalClass>
        + readProcesses(dipPath: string): AsyncGenerator<Process>
        + readDocuments(dipPath: string): AsyncGenerator<Document>
        + readFiles(dipPath: string): AsyncGenerator<File>
        + readFileBytes(file_id: string): AsyncGenerator<Buffer>
    }

    together {
        interface IDocumentalClassRepository {
            + save(documentalClass: DocumentalClass): Promise<void>
        }

        interface IProcessRepository {
            + save(process: Process): Promise<void>
        }

        interface IDocumentRepository {
            + save(document: Document): Promise<void>
        }

        interface IFileRepository {
            + save(file: File): Promise<void>
        }
    }

    ' ENTITA E ENUM
    enum IntegrityStatus {
        UNKNOWN
        VALID
        INVALID
    }

    abstract class ArchivalNode {
        - uuid: string
        - integrityStatus: IntegrityStatus
        + getUuid(): string
        + getIntegrityStatus(): IntegrityStatus
        + setIntegrityStatus(status: IntegrityStatus): void
    }

    together {
        class Dip {
        }

        class DocumentalClass {
            - name: string
            - timestamp: string
            + getName(): string
            + getTimestamp(): string
        }

        class Process {
            - parentDocumentalClassUuid: string
            + getParentDocumentalClassUuid(): string
        }

        class Document {
            - type: string
            - parentProcessUuid: string
            + getType(): string
            + getParentProcessUuid(): string
        }

        class File {
            - hash: string
            - isPrimary: boolean
            - parentDocumentUuid: string
            + getHash(): string
            + getIsPrimary(): boolean
            + getParentDocumentUuid(): string
        }
    }

    ' Subject non estende ArchivalNode — non ha uuid ne integrityStatus
    class Subject {
        - type: string
        + getType(): string
    }

    ' Composite pattern — Metadata contiene Metadata
    class Metadata {
        - name: string
        - value: string | null
        - type: string
        - children: Metadata[]
        + getName(): string
        + getValue(): string | null
        + getType(): string
        + getChildren(): Metadata[]
        + isLeaf(): boolean
    }
}

' --- 4. INFRASTRUTTURA OUTBOUND ---
package "Infrastructure Layer (Outbound)" #fff2e6 {

    package "Parsing" #fce8d5 {

        class DiPIndexParser {
            + parse(xml: string): ParsedDiPIndex
            - parseAiP(aip: any): ParsedAiP
        }

        class DocumentMetadataParser {
            + parse(xml: string, uuid: string): Document
            - traverseNode(name: string, node: any): Metadata
        }

        class ParsedDiPIndex {
            + uuid: string
            + documentalClasses: ParsedDocumentalClass[]
        }

        class ParsedDocumentalClass {
            + uuid: string
            + name: string
            + timestamp: string
            + aips: ParsedAiP[]
        }

        class ParsedAiP {
            + uuid: string
            + root: string
            + documents: ParsedDocument[]
        }

        class ParsedDocument {
            + uuid: string
            + metadataPath: string
            + primaryFile: ParsedFile
            + attachments: ParsedFile[]
        }

        class ParsedFile {
            + uuid: string
            + path: string
        }

        DiPIndexParser ..> ParsedDiPIndex : " <<produces>>"
        ParsedDiPIndex *-- ParsedDocumentalClass
        ParsedDocumentalClass *-- ParsedAiP
        ParsedAiP *-- ParsedDocument
        ParsedDocument *-- ParsedFile
        DocumentMetadataParser ..> Metadata : " <<produces>>"
    }

    class LocalPackageReaderAdapter {
        - indexParser: DiPIndexParser
        - metaParser: DocumentMetadataParser
        - cache: ParsedDiPIndex
        + readDip(dipPath: string): Promise<Dip>
        + readDocumentalClasses(dipPath: string): AsyncGenerator<DocumentalClass>
        + readProcesses(dipPath: string): AsyncGenerator<Process>
        + readDocuments(dipPath: string): AsyncGenerator<Document>
        + readFiles(dipPath: string): AsyncGenerator<File>
        + readFileBytes(file_id: string): AsyncGenerator<Buffer>
        - loadIndex(dipPath: string): Promise<ParsedDiPIndex>
    }

    class SqlitePackageAdapter {
        - db: Database
        + save(documentalClass: DocumentalClass): Promise<void>
        + save(process: Process): Promise<void>
        + save(document: Document): Promise<void>
        + save(file: File): Promise<void>
    }

    LocalPackageReaderAdapter --> DiPIndexParser : " uses"
    LocalPackageReaderAdapter --> DocumentMetadataParser : " uses"
}

' ==========================================
' FLUSSO
' ==========================================

IndexingIpcAdapter -down-> IndexDipUC : " invokes"
IndexDipService -left-> IPackageReaderPort : " reads from"
IndexDipService -down-> IDocumentalClassRepository : " writes to"
IndexDipService -down-> IProcessRepository : " writes to"
IndexDipService -down-> IDocumentRepository : " writes to"
IndexDipService -down-> IFileRepository : " writes to"

LocalPackageReaderAdapter -up-|> IPackageReaderPort : " implements"
SqlitePackageAdapter -up-|> IDocumentalClassRepository : " implements"
SqlitePackageAdapter -up-|> IProcessRepository : " implements"
SqlitePackageAdapter -up-|> IDocumentRepository : " implements"
SqlitePackageAdapter -up-|> IFileRepository : " implements"

' Gerarchia dominio
ArchivalNode .right.> IntegrityStatus : " <<uses>>"

ArchivalNode <|-down- Dip
ArchivalNode <|-down- DocumentalClass
ArchivalNode <|-down- Process
ArchivalNode <|-down- Document
ArchivalNode <|-down- File

' Aggregazioni con Metadata
Process o-down- Metadata : " contains"
Document o-down- Metadata : " contains"
Subject o-down- Metadata : " contains"

' Composite — Metadata contiene Metadata
Metadata "1" o-right- "*" Metadata : " children"

' Relazioni UUID tra nodi (riferimenti logici)
Dip "1" o-right- "many" DocumentalClass : " documentalClassUuids >"
DocumentalClass "1" o-right- "many" Process : " processUuids >"
Process "1" o-right- "many" Document : " documentUuids >"
Document "1" o-right- "many" File : " fileUuids >"
Document "1" o-down- "many" Subject : " subjects >"

@enduml
