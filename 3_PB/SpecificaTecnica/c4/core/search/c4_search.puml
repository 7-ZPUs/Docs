@startuml Class Diagram - Search
top to bottom direction
title Diagramma delle Classi – Search IPC
skinparam linetype ortho
skinparam shadowing false
skinparam wrapWidth 200
skinparam nodesep 60
skinparam ranksep 60
skinparam class {
    BackgroundColor White
    BorderColor #555555
    ArrowColor #333333
    FontSize 12
}
skinparam interface {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

class SearchFilter <<value object>> {
}

class Vector <<value object>> {
}

package "Presentation Layer\n(infrastructure/ipc)" #E8F4FD {
    class SearchIpcAdapter {
        + searchClasses(name?: string): DocumentClass[]
        + searchProcesses(uuid?: string): ArchivalProcess[]
        + searchDocuments(filters: SearchFilter[]): Document[]
        + searchSemantic(query: string): SearchResult[]
        + getAiState(): { initialized: boolean; indexedDocuments: number }
    }
}

package "Business Layer\n(application/use-cases + domain/ports)" #E9F7EF {

    package "Use Cases" {

        interface SearchDocumentalClassUC {
            - searchPort: PackageSearchPort
            + SearchDocumentalClassService(searchPort: PackageSearchPort)
            + execute(name: string): DocumentClass[]
        }

        class SearchDocumentalClassService {
            
        }

        interface SearchProcessiUC {
            - searchPort: PackageSearchPort
            + SearchProcessiService(searchPort: PackageSearchPort)
            + execute(uuid: string): Process[]
        }

        class SearchProcessiService {
            
        }

        interface SearchDocumentsUC {
            - searchPort: PackageSearchPort
            + SearchDocumentsService(searchPort: PackageSearchPort)
            + execute(filters: SearchFilter[]): Document[]
        }

        class SearchDocumentsService {
            
        }

        interface SearchSemanticUC {
            - searchPort: PackageSearchPort
            - embeddingPort: WordEmbeddingPort
            + SearchSemanticService(searchPort: PackageSearchPort, embeddingPort: WordEmbeddingPort)
            + execute(query: string): { id, score }[]
        }

        class SearchSemanticService {
            
        }
    }

    package "Ports" {

        interface PackageSearchPort {
            + searchClasses(name: string): Class[]
            + searchProcesses(uuid: string): Process[]
            + searchDocument(filters: Filter[]): void
            + searchDocumentSemantic(query: string): Promise<List<Document, number>>
        }

        interface WordEmbeddingPort {
            + generateEmbedding(text: string): Promise<Vector>
        }
    }
}

package "Persistence Layer\n(infrastructure/adapters)" #FEF9E7 {

    class SqlitePackageAdapter {
        ' implementa PackageSearchPort (§4) — tutti i metodi della porta
        + searchClasses(name: string): Class[]
        + searchProcesses(uuid: string): Process[]
        + searchDocument(filters: Filter[]): void
        + searchDocumentSemantic(query: string): Promise<List<Document, number>>
    }

    class LocalAiAdapter {
        ' implementa WordEmbeddingPort (§4) — tutti i metodi della porta
        + generateEmbedding(text: string): Promise<Vector>
    }
}

' Presentation → Use Case interfaces
SearchIpcAdapter --> SearchDocumentalClassUC : invoca
SearchIpcAdapter --> SearchProcessiUC        : invoca
SearchIpcAdapter --> SearchDocumentsUC       : invoca
SearchIpcAdapter --> SearchSemanticUC        : invoca
' getAiState(): nessun UC definito nel Markdown, dipendenza diretta
SearchIpcAdapter ..> LocalAiAdapter          : getAiState()

' Services implementano le interfacce UC
SearchDocumentalClassService ..|> SearchDocumentalClassUC : implements
SearchProcessiService        ..|> SearchProcessiUC        : implements
SearchDocumentsService       ..|> SearchDocumentsUC       : implements
SearchSemanticService        ..|> SearchSemanticUC        : implements

' Services → Ports (dipendenze)
SearchDocumentalClassService --> PackageSearchPort : usa
SearchProcessiService        --> PackageSearchPort : usa
SearchDocumentsService       --> PackageSearchPort : usa
SearchSemanticService        --> PackageSearchPort : usa
SearchSemanticService        --> WordEmbeddingPort : usa

' Adapters → Ports (implementazioni)
SqlitePackageAdapter ..|> PackageSearchPort : implements
LocalAiAdapter       ..|> WordEmbeddingPort : implements

' Value Objects
SearchDocumentsService ..> SearchFilter : usa
SearchSemanticService  ..> Vector       : usa

@enduml