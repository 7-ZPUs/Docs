@startuml Class Diagram - Export
top to bottom direction
title Diagramma delle Classi - Export IPC

class FileViewerIpcAdapter {
    +download(fileId: number, targetPath?: string): ExportResult
    +print(fileId: number, targetPath?: string): ExportResult
}

class ExportFileUC {
    +exportFile(id: number, targetPath: string): ExportResult
}

class PrintFileUC {
    +printFile(id: number, targetPath: string): ExportResult
}

interface FileExportPort {
    +exportFile(destPath: string, content: Buffer): Promise<ExportResult>
    +openWriteStream(destPath: string, source: Readable): Promise<void>
}

interface PrintPort {
    +printFile(buffer: Buffer): Promise<PrintResult>
}

class ElectronSystemAdapter {
    +exportFile(destPath: string, content: Buffer): Promise<ExportResult>
    +openWriteStream(destPath: string, source: Readable): Promise<void>
    +printFile(buffer: Buffer): Promise<PrintResult>
}

FileViewerIpcAdapter --> ExportFileUC
FileViewerIpcAdapter --> PrintFileUC

ExportFileUC --> FileExportPort : usa
PrintFileUC --> PrintPort : usa

ElectronSystemAdapter ..|> FileExportPort
ElectronSystemAdapter ..|> PrintPort

@enduml

