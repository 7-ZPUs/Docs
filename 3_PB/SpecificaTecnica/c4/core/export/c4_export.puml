@startuml Class Diagram - Export
top to bottom direction
title Diagramma delle Classi - Export IPC

skinparam linetype ortho
skinparam nodesep 50
skinparam ranksep 60
skinparam groupInheritance 2

skinparam class {
    BackgroundColor White
    BorderColor #555555
    ArrowColor #333333
    FontSize 12
}

skinparam interface {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

class ExportResult <<value object>> {
    + success: boolean
    + errorCode?: string
    + errorMessage?: string
}

class PrintResult <<value object>> {
    + success: boolean
    + errorCode?: string
    + errorMessage?: string
}

package "Application Layer (ipc)" #E8F4FD {

    class FileViewerIpcAdapter {
        + getById(id: string): File
        + openExternal(path: string): { success: boolean }
        + openInWindow(path: string): { success: boolean }
        + download(fileId: number, targetPath?: string): { success: boolean; savedPath?: string }
        + print(fileId: number, targetPath?: string): { success: boolean; savedPath?: string }
    }
}

package "Business Layer (application + domain)" #E9F7EF {

    package "Use Cases" {

        interface ExportFileUC {
            - readerPort: PackageReaderPort
            - exportPort: FileExportPort
            + ExportFileService(readerPort: PackageReaderPort, exportPort: FileExportPort)
            + execute(id: number, targetPath: string): ExportResult
        }

        class ExportFileService {
            
        }

        interface PrintFileUC {
            - readerPort: PackageReaderPort
            - printPort: PrintPort
            + PrintFileService(readerPort: PackageReaderPort, printPort: PrintPort)
            + execute(id: number, targetPath: string): PrintResult
        }

        class PrintFileService {
            
        }

    }

    package "Ports" {

        interface PackageReaderPort {
            + getClasses(): Promise<DocumentClass[]>
            + getProcesses(): Promise<Process[]>
            + getDocuments(): Promise<Document[]>
            + getFiles(): Promise<File[]>
            + readFileBytes(file_id): Promise<Buffer>
            + openReadStream(file_id): Promise<Readable>
        }

        interface FileExportPort {
            + exportFile(destPath: string, content: Buffer): Promise<ExportResult>
            + openWriteStream(destPath: string, source: Readable): Promise<void>
        }

        interface PrintPort {
            + printFile(buffer: Buffer): Promise<PrintResult>
        }
    }
}

package "Persistence Layer (adapters)" #FEF9E7 {

    class LocalPackageReaderAdapter {
        - packagePath: string
        + getClasses(): Promise<DocumentClass[]>
        + getProcesses(): Promise<Process[]>
        + getDocuments(): Promise<Document[]>
        + getFiles(): Promise<File[]>
        + readFileBytes(file_id): Promise<Buffer>
        + openReadStream(file_id): Promise<Readable>
    }

    class ElectronSystemAdapter {
        + exportFile(destPath: string, content: Buffer): Promise<ExportResult>
        + openWriteStream(destPath: string, source: Readable): Promise<void>
        + printFile(buffer: Buffer): Promise<PrintResult>
    }
}

FileViewerIpcAdapter --> ExportFileService  : invoca
FileViewerIpcAdapter --> PrintFileService   : invoca

ExportFileService ..|> ExportFileUC : implements
PrintFileService  ..|> PrintFileUC  : implements

ExportFileUC  --> PackageReaderPort : usa
ExportFileUC  --> FileExportPort    : usa
PrintFileUC   --> PackageReaderPort : usa
PrintFileUC   --> PrintPort         : usa

LocalPackageReaderAdapter ..|> PackageReaderPort : implements
ElectronSystemAdapter     ..|> FileExportPort    : implements
ElectronSystemAdapter     ..|> PrintPort         : implements

ExportFileUC ..> ExportResult : returns
PrintFileUC  ..> PrintResult  : returns

@enduml
