' ════════════════════════════════════════════════════════
' LAYER 0 – INTERFACES & CONTRACTS  (ISP + DIP)
' ════════════════════════════════════════════════════════
package "Interfaces & Contracts" #F0FDF4 {

  interface ISearchFacade <<ISP>> {
    + getState(): Signal<SearchState>
    + setQuery(query: SearchQuery): void
    ' Updates query in state only. Does NOT trigger search.
    ' Precondition for search(): must be called before search() to set the query.
    + search(): void
    ' Triggers full-text search using current state.query.
    ' Precondition: state.query must have been set via setQuery() before calling search().
    ' Debounce 300ms applied inside the Facade (toObservable + debounceTime).
    ' No-op if isSearching === true (mutex guard).
    ' CQS: results → Signal<SearchState>.results.
    + setFilters(filters: SearchFilters): void
    ' Updates filters in state only. Does NOT trigger search.
    ' Call searchAdvanced() to apply filters and search.
    + searchAdvanced(filters: SearchFilters): void
    ' Calls setFilters() internally, then triggers advanced search.
    ' CQS: validation errors → Signal<SearchState>.validationErrors, not return value.
    + searchSemantic(query: SearchQuery): void
    + cancelSearch(): void
    + retry(): void
    ' CQS: isSearching guard reflected in Signal<SearchState>.isSearching.
  }

  interface ISearchChannel <<ISP>> {
    + search(q: SearchQuery, s: AbortSignal): Observable<SearchResult[]>
    + searchAdvanced(f: SearchFilters, s: AbortSignal): Observable<SearchResult[]>
    + searchSemantic(q: SearchQuery, s: AbortSignal): Observable<SearchResult[]>
  }

  interface IIndexingChannel <<ISP>> {
    + getIndexingStatus(): Observable<SemanticIndexState>
    + cancel(): Observable<void>
  }

  interface IFilterValidator <<ISP>> {
    + validate(filters: PartialFilters): ValidationResult
    + validateField(field: string, value: unknown, type: FilterFieldType): ValidationError | null
  }

  interface ISemanticIndexStatus <<ISP>> {
    + getStatus(): Signal<SemanticIndexState>
  }

  interface ISemanticIndexControl <<ISP>> {
    + cancelIndexing(): void
  }

  interface ICacheService <<ISP>> {
    + get<T>(key: string): T | null
    + set<T>(key: string, value: T, ttlMs: number): void
    + invalidate(key: string): void
    + invalidatePrefix(prefix: string): void
    ' Used by SearchIpcGateway on abort; by IpcCacheService on DIP reload
  }

  interface IErrorHandler <<ISP>> {
    + handle(raw: unknown): AppError
    ' isRecoverable() removed: AppError.recoverable is a public field; callers read it directly.
    + createError(code: ErrorCode, message: string, source: string): AppError
  }

  interface ITelemetry <<ISP>> {
    + trackEvent(name: TelemetryEvent): void
    + trackTiming(metric: TelemetryMetric, ms: number): void
    + trackError(error: AppError): void
  }

  interface ILiveAnnouncer <<ISP>> {
    + announce(message: string, politeness?: "polite"|"assertive"): void
  }

  interface IDocumentFacade <<ISP>> {
    + getFileBlob(documentId: string): Observable<DocumentBlob>
    ' Returns raw binary blob (ArrayBuffer + mimeType). Cached TTL 60s.
    + getDocumentMetadata(documentId: string): Observable<DocumentMetadata>
    ' Returns parsed metadata. Cached TTL 300s.
    + getAipInfo(documentId: string): Observable<AipInfo>
    + getError(): Signal<AppError | null>
    ' loadDocument() removed: was a duplicate of getFileBlob() with identical signature and return type (DRY fix).
  }

  interface ISubjectDetailStrategy <<ISP>> {
    + getFields(): SubjectFieldDefinition[]
    ' Each strategy already IS a specific SubjectType; the type parameter is redundant
    ' and forces implementors to ignore or guard on it (LSP violation). Removed.
  }

  interface IFieldValidatorStrategy <<ISP>> {
    + validate(field: string, value: unknown): ValidationError | null
  }

  interface IRouter <<ISP>> {
    + navigate(commands: (string|number|object)[], extras?: object): Promise<boolean>
    ' Defined here (Layer 0) so Smart Components depend on the abstraction, not Angular Router.
  }

  interface IAngularRouter <<ISP>> {
    ' Minimal wrapper around Angular Router exposing only what AppRouter needs.
    ' Kept in Layer 0 so AppRouter (Layer 3) depends downward on the abstraction.
    ' Concrete binding: provide Angular Router via useExisting in AppModule.
    + navigate(commands: unknown[], extras?: object): Promise<boolean>
  }

  interface IElectronContextBridge <<ISP>> {
    + invoke<T>(channel: string, payload: unknown, s?: AbortSignal): Promise<T>
    ' Abstraction over Electron contextBridge.exposeInMainWorld.
    ' Implemented by a thin wrapper injected at bootstrap; mock-replaced in tests.
  }

  interface ILoggingChannel <<ISP>> {
    + writeLog(entry: LogEntry): Observable<void>
  }
}

