  class AppError {
    + code: ErrorCode
    + category: ErrorCategory
    + severity: ErrorSeverity
    + recoverable: boolean
    + context?: string
    + detail?: string
  }

  class SearchState {
    + query: SearchQuery
    + filters: SearchFilter
    + results: SearchResult[]
    + loading: boolean
    + error: AppError | null
    + validationErrors: Map<string, ValidationError>
    + isSearching: boolean
  }

  class SemanticIndexState {
    + status: IndexingStatus
    + progress: number
    + error: AppError | null
  }

  class CustomMetaEntry {
    + name: string
    + value: string
