' ════════════════════════════════════════════════════════
' INTERFACE IMPLEMENTATIONS & DI TOKENS
' ════════════════════════════════════════════════════════

SearchFacade           ..|> ISearchFacade
SemanticIndexFacade    ..|> ISemanticIndexStatus
SemanticIndexFacade    ..|> ISemanticIndexControl
FilterValidatorService ..|> IFilterValidator
SearchIpcGateway       ..|> ISearchChannel
IndexingIpcGateway     ..|> IIndexingChannel
IpcCacheService        ..|> ICacheService
IpcErrorHandlerService ..|> IErrorHandler
TelemetryService       ..|> ITelemetry
TelemetryService       --> ILoggingChannel : <<uses>>
LiveAnnouncerService   ..|> ILiveAnnouncer
DocumentFacade         ..|> IDocumentFacade
AppRouter              ..|> IRouter
DocumentViewerComponent ..> IDocumentFacade : "<<inject>>"

' ════════════════════════════════════════════════════════
' SERVICE WIRE-UP  (all via interfaces — DIP)
' ════════════════════════════════════════════════════════

SearchFacade --> ISearchChannel       : <<uses>>
SearchFacade --> IFilterValidator     : <<uses>>
SearchFacade --> IErrorHandler        : <<uses>>
SearchFacade --> ITelemetry           : <<uses>>
SearchFacade --> ISemanticIndexStatus : <<uses>>
SearchFacade --> ICacheService        : "<<uses>>\ninvalidate on abort"
SearchFacade --> ILiveAnnouncer       : "<<uses>>\nannuncia transizioni di stato"

SemanticIndexFacade --> IIndexingChannel : <<uses>>

SearchIpcGateway   --> ICacheService          : <<uses>>
SearchIpcGateway   --> IErrorHandler          : <<uses>>
SearchIpcGateway   --> IElectronContextBridge : <<uses>>
IndexingIpcGateway --> IErrorHandler          : <<uses>>
IndexingIpcGateway --> IElectronContextBridge : <<uses>>

FilterValidatorService --> IFieldValidatorStrategy : "<<uses>>\nMap<FilterFieldType, strategy>  [OCP registry]"
SubjectDetailFormComponent ..> ISubjectDetailStrategy : "<<uses>>\nMap<SubjectType, strategy>  [OCP registry]"

DipReadyGuard ..> IDipReadyChecker : "<<inject()>>"

SearchFacade        *--> SearchState        : "owns WritableSignal<>\n(current value)"
SemanticIndexFacade *--> SemanticIndexState : "owns WritableSignal<>\n(current value)"

' ════════════════════════════════════════════════════════
' DOMAIN ASSOCIATIONS
' ════════════════════════════════════════════════════════

SearchState      "1" o-- "1"    SearchQuery
SearchState      "1" o-- "1"    SearchFilters
SearchState      "1" o-- "*"    SearchResult

SearchPageComponent *--> ValidationResult : "uiValidation\nWritableSignal<>"
ValidationResult "1" o-- "*"    ValidationError
SearchFilters    "1" o-- "0..1" SubjectCriteria

IpcCacheService  *--> CacheEntry : "store Map<string, CacheEntry>"
TelemetryService --> LogEntry    : "<<creates>>"

' ════════════════════════════════════════════════════════
' DATA FLOW  –  SMART ↔ DUMB
' ════════════════════════════════════════════════════════

SearchPageComponent -[#6B21A8,dashed]-> ISearchFacade \
  : "<<inject>> reads Signal\ndispatches: setQuery/searchAdvanced/searchSemantic/retry"

SearchPageComponent -[#6B21A8,dashed]-> ISemanticIndexControl \
  : "<<inject>> cancelIndexing() when status===INDEXING"

SearchPageComponent -[#6B21A8,dashed]-> ISemanticIndexStatus \
  : "<<inject>> reads getStatus() for indexingStatus Signal"

SearchPageComponent -[#6B21A8,dashed]-> IRouter \
  : "<<inject>> navigate(['/document'|'/aggregate', id])"

SearchPageComponent -[#1D4ED8]-> SearchBarComponent \
  : "▼ @Input query, isSearching, defaultType, defaultUseSemantic"
SearchBarComponent -[#15803D]-> SearchPageComponent \
  : "▲ @Output queryChanged: SearchQuery"

SearchPageComponent -[#1D4ED8]-> AdvancedFilterPanelComponent \
  : "▼ @Input filters: SearchFilters\n▼ @Input validator: FilterValidatorFn\n▼ @Input externalValidation = uiValidation()"
AdvancedFilterPanelComponent -[#15803D]-> SearchPageComponent \
  : "▲ @Output filtersChanged: SearchFilters\n▲ @Output filtersSubmit: SearchFilters\n▲ @Output validationResult: ValidationResult"

SearchPageComponent -[#1D4ED8]-> SearchResultsComponent \
  : "▼ @Input results: SearchResult[]\n▼ @Input emptyMessage: string"
SearchResultsComponent -[#15803D]-> SearchPageComponent \
  : "▲ @Output resultSelected: string (documentId)"

SearchPageComponent -[#1D4ED8]-> SemanticIndexStatusComponent \
  : "▼ @Input indexingState = semanticStatus.getStatus()()"
SemanticIndexStatusComponent -[#15803D]-> SearchPageComponent \
  : "▲ @Output cancelRequested"

SearchPageComponent -[#1D4ED8]-> AsyncStateWrapperComponent \
  : "▼ @Input loading = SearchState.loading\n▼ @Input error = SearchState.error\n▼ @Input empty = results.length === 0"
AsyncStateWrapperComponent -[#15803D]-> SearchPageComponent \
  : "▲ @Output retryClicked"

SearchPageComponent -[#1D4ED8]-> DocumentViewerComponent \
  : "▼ @Input documentId = selectedDocumentId()\n[conditional render]"
DocumentViewerComponent -[#15803D]-> SearchPageComponent \
  : "▲ @Output viewerError: AppError\n▲ @Output loadingChanged: boolean"

SearchPageComponent -[#1D4ED8]-> InlineErrorComponent \
  : "▼ @Input error: viewerError() [viewer slot]"
InlineErrorComponent -[#15803D]-> SearchPageComponent \
  : "▲ @Output retryClicked"

' ── AdvancedFilterPanelComponent (Dumb) ↔ sub-panels ────

AdvancedFilterPanelComponent -[#1D4ED8]-> SubjectFilterComponent \
  : "▼ @Input subject = filters.subject\n▼ @Input resetCounter"
SubjectFilterComponent -[#15803D]-> AdvancedFilterPanelComponent \
  : "▲ @Output subjectChanged"

AdvancedFilterPanelComponent -[#1D4ED8]-> CommonFiltersComponent \
  : "▼ @Input filters: CommonFilterValues\n▼ @Input validationResult: ValidationResult"
CommonFiltersComponent -[#15803D]-> AdvancedFilterPanelComponent \
  : "▲ @Output filtersChanged\n▲ @Output validationError"

AdvancedFilterPanelComponent -[#1D4ED8]-> DiDaiFiltersComponent \
  : "▼ @Input filters: DiDaiFilterValues\n▼ @Input validationResult: ValidationResult"
