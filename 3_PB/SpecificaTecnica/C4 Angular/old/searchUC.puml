' ══════════════════════════════════════════════════════════════
' ENUMS & VALUE TYPES
' ══════════════════════════════════════════════════════════════

package "Types & Enums" #F5F5F5 {

  enum IndexingStatus {
    IDLE
    INDEXING
    READY
    ERROR
    TIMEOUT
    CANCELLED
  }

  enum FilterFieldType {
    TEXT
    DATE
    NUMERIC
    ENUM
  }

  enum SubjectType {
    PAI
    PAE
    AS
    PG
    PF
    RUP
    SW
  }

  class SearchQuery {
    + text: string
    + className?: string
    + processId?: string
  }

  class SearchFilter {
    + common?: CommonFilterValues
    + diDai?: DiDaiFilterValues
    + aggregate?: AggregateFilterValues
    + customMeta?: CustomMetaEntry[]
    + subject?: SubjectFilter
  }

  class SearchResult {
    + id: string
    + name: string
    + type: string
  }

  class ValidationError {
    + field: string
    + message: string
  }

  class ValidationResult {
    + valid: boolean
    + errors: Map<string, ValidationError>
  }

  class AppError {
    + code: ErrorCode
    + category: ErrorCategory
    + severity: ErrorSeverity
    + recoverable: boolean
    + context?: string
    + detail?: string
  }

  class SearchState {
    + query: SearchQuery
    + filters: SearchFilter
    + results: SearchResult[]
    + loading: boolean
    + error: AppError | null
    + validationErrors: Map<string, ValidationError>
    + isSearching: boolean
  }

  class SemanticIndexState {
    + status: IndexingStatus
    + progress: number
    + error: AppError | null
  }

  class CustomMetaEntry {
    + name: string
    + value: string
  }
}

