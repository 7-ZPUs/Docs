' ══════════════════════════════════════════════════════════════

package "Routing & Guard" #E8F5E9 {

  class AppRouter {
    + routes: Route[]
    + navigate(path: string[], extras?): void
  }

  class DipReadyGuard <<CanActivateFn>> {
    + canActivate(route, state): boolean | UrlTree
