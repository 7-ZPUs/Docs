' ══════════════════════════════════════════════════════════════
' FACADE SERVICES
' ══════════════════════════════════════════════════════════════

package "Facade Services" #EDE7F6 {

  class SearchFacade <<Angular Service [Injectable]\nFacade + SRP>> {
    + state: Signal<SearchState>
    - abortController: AbortController
    - isSearching: Signal<boolean>
    + search(query: SearchQuery): void
    + searchAdvanced(filters: SearchFilter): void
    + searchSemantic(query: SearchQuery): void
    + cancelSearch(): void
    - debounce(fn, ms: 300): void
    - checkSemanticAvailability(): boolean
    ' Dependencies injected:
    - ipcGateway: IpcGateway
    - filterValidator: FilterValidatorService
    - ipcErrorHandler: IpcErrorHandlerService
    - telemetry: TelemetryService
    - liveAnnouncer: LiveAnnouncerService
    - semanticFacade: SemanticIndexFacade
  }

  class SemanticIndexFacade <<Angular Service [Injectable]\nFacade – Opzionale>> {
    + state: Signal<SemanticIndexState>
    + cancel(): void
    - timeout: 120 <<seconds>>
    - ipcGateway: IpcGateway
    - liveAnnouncer: LiveAnnouncerService
  }
}

' ══════════════════════════════════════════════════════════════
' SERVICES
' ══════════════════════════════════════════════════════════════

package "Services" #E8EAF6 {

  class FilterValidatorService <<Angular Service [providedIn:'root']\nSRP – Validation>> {
    + validate(filters: SearchFilter): ValidationResult
    + validateField(field: string, value: string, type: FilterFieldType): ValidationError | null
  }

  class IpcGateway <<Angular Service [providedIn:'root']\nAdapter + ISP>> {
    + invoke<T>(channel: string, payload?, cachePolicy?): Promise<T>
    + on<T>(channel: string, handler): () => void
    ' Search channels:
    '   search           → cache-first, TTL 30s
    '   searchAdvanced   → cache-first, TTL 30s + AbortController
    '   searchSemantic   → no-cache if status≠ready
    - ipcCache: IpcCacheService
    - ipcErrorHandler: IpcErrorHandlerService
  }

  class IpcCacheService <<Angular Service [providedIn:'root']\nSRP – Request Deduplication>> {
    - entries: Map<string, CacheEntry>
    + get<T>(key: string): T | null
    + set<T>(key: string, value: T, ttl: number): void
    + invalidate(key: string): void
    + invalidatePrefix(prefix: string): void
    + clear(): void
    ' search results TTL: 30_000ms
  }

  class IpcErrorHandlerService <<Angular Service [providedIn:'root']\nSRP – Error Translation>> {
    + toAppError(ipcError: unknown): AppError
    + isFatal(e: AppError): boolean
    ' SEARCH_ENGINE_ERROR → AppError in Signal<SearchState>
  }

  class TelemetryService <<Angular Service [providedIn:'root']\nSRP – Observability>> {
    + trackEvent(type: EventType, payload?): void
    + trackError(error: AppError, context?): void
    + trackTiming(label: EventType, ms: number): void
    ' Events: SEARCH_EXECUTED, SEARCH_LATENCY_MS,
    '         SEARCH_RESULT_OPENED, IPC_ERROR
    - ipcGateway: IpcGateway
  }

  class LiveAnnouncerService <<Angular CDK [providedIn:'root']\nWCAG 2.1 – aria-live>> {
    + announce(msg: string, politeness?: 'polite' | 'assertive'): void
    ' SearchFacade → "Trovati N risultati" [polite] – UC-15
  }
}

