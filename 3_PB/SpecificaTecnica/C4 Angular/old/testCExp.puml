title UC-3 Search – Class Diagram  ·  Smart / Dumb Pattern\n(SOLID · SRP · OCP · LSP · ISP · DIP)

skinparam classAttributeIconSize 0
skinparam classFontSize 11
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 80

' ── Smart component skin (blue header) ──────────────────
skinparam class {
  BackgroundColor          White
  BorderColor              #334155
  HeaderBackgroundColor    #DBEAFE
  FontColor                #1E293B
  AttributeFontColor       #334155
}

' ── Package backgrounds ──────────────────────────────────
skinparam packageBackgroundColor #F8FAFC
skinparam packageBorderColor     #94A3B8

' ── Arrow colours by type ────────────────────────────────
'    @Input  (state DOWN)  → blue solid
'    @Output (event UP)    → green dashed
