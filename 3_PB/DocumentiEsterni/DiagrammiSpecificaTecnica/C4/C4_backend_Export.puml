@startuml Export_IPC_Part1
scale 1.0
title Diagramma delle Classi — Export IPC (Parte 1)\nUse Cases + ExportResult

skinparam linetype ortho
skinparam nodesep 30
skinparam ranksep 40
top to bottom direction
skinparam groupInheritance 2
skinparam pageMargin 10
skinparam dpi 150

skinparam defaultFontSize 12
skinparam defaultFontName Arial

skinparam class {
    BackgroundColor White
    BorderColor #555555
    ArrowColor #333333
    FontSize 12
    HeaderBackgroundColor #F0F0F0
    AttributeFontSize 11
}

skinparam interface {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
    FontSize 12
}

skinparam package {
    FontSize 11
    BorderColor #999999
}

package "Application Layer (ipc)" as ipc{
    class FileViewerIpcAdapter {
        + {static} register(ipcMain: IpcMain): void
    }
}

package "Business Layer" as core  {
    package "Use Cases" as uc {
        interface IExportFileUC {
            + execute(fileId: number, targetPath: string): Promise<ExportResult>
        }

        interface IPrintFileUC {
            + execute(fileId: number): Promise<ExportResult>
        }

        class ExportFileUC {
            - fileRepo: IFileRepository
            - exportPort: IExportPort
            - packageReader: IFileSystemPort
            - dipPath: string
            + execute(fileId: number, targetPath: string): Promise<ExportResult>
        }

        class PrintFileUC {
            - fileRepo: IFileRepository
            - dipPath: string
            - printPort: IPrintPort
            + execute(fileId: number): Promise<ExportResult>
        }
    }
}

class ExportResult <<value object>> {
    + success: boolean
    + errorCode?: string
    + errorMessage?: string
    + {static} ok(): ExportResult
    + {static} fail(code: string, msg: string): ExportResult
}

ipc -[hidden]down-> core

FileViewerIpcAdapter --> ExportFileUC : invoca
FileViewerIpcAdapter --> PrintFileUC  : invoca

ExportFileUC ..|> IExportFileUC
PrintFileUC  ..|> IPrintFileUC

ExportFileUC ..> ExportResult : <<returns>>
PrintFileUC  ..> ExportResult : <<returns>>
@enduml

@startuml Export_IPC_Part2
scale 0.9
title Diagramma delle Classi — Export IPC (Parte 2)\nUse Cases + Ports (interfacce)

skinparam linetype ortho
skinparam nodesep 30
skinparam ranksep 40
top to bottom direction
skinparam groupInheritance 2
skinparam pageMargin 10
skinparam dpi 150

skinparam defaultFontSize 12
skinparam defaultFontName Arial

skinparam class {
    BackgroundColor White
    BorderColor #555555
    ArrowColor #333333
    FontSize 12
    HeaderBackgroundColor #F0F0F0
    AttributeFontSize 11
}

skinparam interface {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
    FontSize 12
}

skinparam package {
    FontSize 11
    BorderColor #999999
}

package "Business Layer" as core  {
    package "Use Cases" as uc {
        class ExportFileUC {
            - fileRepo: IFileRepository
            - exportPort: IExportPort
            - packageReader: IFileSystemPort
            - dipPath: string
            + execute(fileId: number, targetPath: string): Promise<ExportResult>
        }

        class PrintFileUC {
            - fileRepo: IFileRepository
            - dipPath: string
            - printPort: IPrintPort
            + execute(fileId: number): Promise<ExportResult>
        }
    }

    package "Ports" as ports {
        interface IFileSystemPort {
            + readFileBytes(filePath: string): Promise<Buffer>
        }

        interface IExportPort {
            + exportFile(stream: ReadableStream, destPath: string): Promise<ExportResult>
        }

        interface IPrintPort {
            + printSingle(absolutePath: string, opts: PrintOptions): Promise<ExportResult>
        }
    }
}

class ExportResult <<value object>>  {
    + success: boolean
    + errorCode?: string
    + errorMessage?: string
    + {static} ok(): ExportResult
    + {static} fail(code: string, msg: string): ExportResult
}

uc -[hidden]down-> ports

ExportFileUC --> IFileSystemPort : usa
ExportFileUC --> IExportPort     : usa
PrintFileUC  --> IPrintPort      : usa

ExportFileUC ..> ExportResult : <<returns>>
PrintFileUC  ..> ExportResult : <<returns>>
@enduml


