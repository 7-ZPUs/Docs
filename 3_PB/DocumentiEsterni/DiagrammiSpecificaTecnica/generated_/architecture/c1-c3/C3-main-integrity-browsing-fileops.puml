@startuml C3_Main_Integrity_Browsing_FileOps
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title C4 Model - Level 3 (Main Process Components: Integrity, Browsing, File Operations)

LAYOUT_WITH_LEGEND()

Container_Boundary(main_container, "Main Process") {
  Component(browsing_ipc, "BrowsingIpcAdapter", "IPC Inbound Adapter", "Read/navigation channels by id/status/relations")
  Component(integrity_ipc, "CheckIntegrityIpcAdapter", "IPC Inbound Adapter", "Integrity check channels for Dip/Class/Process/Document/File")
  Component(file_ipc, "FileViewerIpcAdapter", "IPC Inbound Adapter", "Download/save/print dialogs and file operations")

  Component(browse_ucs, "Browsing Use Cases", "Application Services", "GetById/GetByStatus/GetByParent for Dip/Class/Process/Document/File")
  Component(integrity_ucs, "Integrity Use Cases", "Application Services", "Check integrity status across hierarchy")
  Component(file_ucs, "File Use Cases", "Application Services", "ExportFileUC, PrintFileUC, GetFileContentUC")

  Component(integrity_service, "IntegrityVerificationService", "Domain Service", "Hash verification and integrity computation")

  Component(dip_repo, "DipRepository", "Repository", "Dip persistence")
  Component(class_repo, "DocumentClassRepository", "Repository", "Class persistence")
  Component(process_repo, "ProcessRepository", "Repository", "Process persistence")
  Component(doc_repo, "DocumentRepository", "Repository", "Document persistence")
  Component(file_repo, "FileRepository", "Repository", "File persistence")

  Component(export_port, "LocalExportPort", "Outbound Adapter", "Writes files to user-selected path")
  Component(print_port, "PrintPort", "Outbound Adapter", "Print integration")
  Component(package_reader, "LocalPackageReaderAdapter", "Outbound Adapter", "Reads file stream from DIP")
}

Container_Ext(renderer, "Renderer UI", "Angular", "Browse tree, integrity actions, download/print actions")
ContainerDb_Ext(sqlite, "SQLite", "Entity and status persistence")
System_Ext(local_fs, "Local File System", "DIP files and target export directories")
System_Ext(os_services, "OS Print/File Services", "Native print and file dialogs")

Rel(renderer, browsing_ipc, "browse:* channels")
Rel(renderer, integrity_ipc, "check-integrity:* channels")
Rel(renderer, file_ipc, "file:* channels")

Rel(browsing_ipc, browse_ucs, "execute")
Rel(integrity_ipc, integrity_ucs, "execute")
Rel(file_ipc, file_ucs, "execute")

Rel(integrity_ucs, integrity_service, "verify")

Rel(browse_ucs, dip_repo, "read")
Rel(browse_ucs, class_repo, "read")
Rel(browse_ucs, process_repo, "read")
Rel(browse_ucs, doc_repo, "read")
Rel(browse_ucs, file_repo, "read")

Rel(integrity_ucs, dip_repo, "read/update status")
Rel(integrity_ucs, class_repo, "read/update status")
Rel(integrity_ucs, process_repo, "read/update status")
Rel(integrity_ucs, doc_repo, "read/update status")
Rel(integrity_ucs, file_repo, "read/update status")

Rel(file_ucs, package_reader, "read file bytes")
Rel(file_ucs, export_port, "export file")
Rel(file_ucs, print_port, "print file")

Rel(dip_repo, sqlite, "SQL io")
Rel(class_repo, sqlite, "SQL io")
Rel(process_repo, sqlite, "SQL io")
Rel(doc_repo, sqlite, "SQL io")
Rel(file_repo, sqlite, "SQL io")

Rel(package_reader, local_fs, "read streams")
Rel(export_port, local_fs, "write output")
Rel(print_port, os_services, "print")
Rel(file_ipc, os_services, "save/open dialogs")

note right of integrity_ucs
SOLID:
- I: separate use-case interfaces per capability
- D: use cases rely on repo/service abstractions

Patterns:
- Ports & Adapters
- Repository
- Adapter for OS integration
end note

@enduml
