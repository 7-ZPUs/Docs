@startuml Component Diagram - Export
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
title Component Diagram - Export\n(file:download, file:print)

LAYOUT_TOP_DOWN()
skinparam linetype ortho
skinparam shadowing false
skinparam wrapWidth 200
skinparam nodesep 60
skinparam ranksep 60

Component_Ext(renderer,   "Renderer Process", "Angular / TypeScript", "Invia comandi di export e stampa via IPC bridge.")
Component_Ext(filesystem, "File System",       "OS / Local Disk",      "Salvataggio file su disco utente.")

Container_Boundary(main, "Main Process - Electron") {
    Component(file_ipc,       "FileViewerIpcAdapter",   "Node.js / TypeScript", "Canali: FILE_DOWNLOAD, FILE_PRINT,\nFILE_SAVE_DIALOG, FILE_FOLDER_DIALOG")
    Component(uc_export_file, "ExportFileUC",           "Node.js / TypeScript", "Recupera il file dal repository, risolve il percorso assoluto e delega l'esportazione su disco.")
    Component(uc_print_file,  "PrintFileUC",            "Node.js / TypeScript", "Recupera il file dal repository, risolve il percorso assoluto e delega la stampa.")
    Component(port_export,    "IExportPort",            "Interface",            "exportFile(stream, destPath): Promise<ExportResult>")
    Component(port_print,     "IPrintPort",             "Interface",            "printSingle(absolutePath, opts): Promise<ExportResult>")
    Component(local_export,   "LocalExportPort",        "Node.js / TypeScript", "Implementa IExportPort. Scrive lo stream su disco tramite pipeline Node.js.")
    Component(print_port,     "PrintPort",              "Electron",             "Implementa IPrintPort. Crea una BrowserWindow nascosta e stampa il file tramite le API Electron.")
}

Rel_D(renderer,       file_ipc,       "FILE_DOWNLOAD, FILE_PRINT", "Electron IPC")
Rel_D(file_ipc,       uc_export_file, "FILE_DOWNLOAD")
Rel_D(file_ipc,       uc_print_file,  "FILE_PRINT")
Rel_D(uc_export_file, port_export,    "exportFile(stream, destPath)")
Rel_D(uc_print_file,  port_print,     "printSingle(absolutePath, opts)")
Rel_D(port_export,    local_export,   "implementa")
Rel_D(port_print,     print_port,     "implementa")
Rel_D(local_export,   filesystem,     "write (pipeline stream su disco)")

@enduml
