@startuml C3_Main_File_Operations
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Modello C4 - Livello 3 (Componenti processo Main: Operazioni file)

LAYOUT_WITH_LEGEND()

Container_Boundary(main_container, "Processo Main") {
  Component(file_ipc, "FileViewerIpcAdapter", "Adapter IPC di ingresso", "Canali di download, salvataggio e stampa")
  Component(file_ucs, "Use case File", "Servizi applicativi", "ExportFileUC, PrintFileUC, GetFileContentUC")

  Component(package_reader, "LocalPackageReaderAdapter", "Adapter outbound", "Legge byte file dal pacchetto DIP")
  Component(export_port, "LocalExportPort", "Adapter outbound", "Scrive file nella destinazione selezionata")
  Component(print_port, "PrintPort", "Adapter outbound", "Integrazione stampa")
  Component(file_repo, "FileRepository", "Repository", "Ricerca metadati file")
}

Container_Ext(renderer, "Renderer UI", "Angular", "Azioni di download, salvataggio e stampa")
ContainerDb_Ext(sqlite, "SQLite", "Persistenza metadati file")
System_Ext(local_fs, "File system locale", "File DIP e directory di export")
System_Ext(os_services, "Servizi OS stampa e file", "Dialog nativi di stampa e file")

Rel(renderer, file_ipc, "canali file:*")
Rel(file_ipc, file_ucs, "esegue")

Rel(file_ucs, file_repo, "legge metadati")
Rel(file_ucs, package_reader, "legge byte file")
Rel(file_ucs, export_port, "esporta file")
Rel(file_ucs, print_port, "stampa file")

Rel(file_repo, sqlite, "lettura SQL")
Rel(package_reader, local_fs, "legge stream")
Rel(export_port, local_fs, "scrive output")
Rel(print_port, os_services, "stampa")
Rel(file_ipc, os_services, "dialog salvataggio e apertura")

note right of file_ucs
Pattern:
- Porte e adapter
- Repository per metadati
- Isolamento adapter per integrazioni OS
end note

@enduml
