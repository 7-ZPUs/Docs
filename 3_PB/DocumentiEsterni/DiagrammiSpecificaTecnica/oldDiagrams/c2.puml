@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Container Context Diagram per DipReader

Person(user, "Utente", "Revisore, archivista o cittadino che necessita di consultare e verificare l'archivio.")
System_Ext(filesystem, "File System Locale", "Fornisce il pacchetto DIP originario e funge da destinazione per i file esportati/scaricati.")
System_Ext(printer, "Stampante", "Dispositivo di output per la stampa dei documenti.")

System_Boundary(dipreader_app, "DIPReader App (Electron)") {
    Container(renderer, "Renderer UI", "Angular, TypeScript", "Fornisce l'interfaccia visiva per la navigazione, la ricerca e la visualizzazione dei documenti.")
    Container(main, "Main", "Node.js, TypeScript", "Processo principale che gestisce la logica di business pesante, l'indicizzazione e l'accesso diretto alle risorse locali.")
    ContainerDb(sqlite, "Relational Database", "SQLite3 + sqlite-vss", "Memorizza i metadati XML indicizzati")
    ContainerDb(sqlite_vss, "Vector  Database", "SQLite3 + sqlite-vss", "Memorizza i vettori generati per la ricerca semantica.")
    Container(llm_models, "Local LLM Models", "File .onnx", "Modelli AI inclusi nel pacchetto per garantire l'inferenza completamente offline.")
}

Rel(user, renderer, "Interagisce con l'interfaccia grafica tramite")
Rel(renderer, main, "Invia comandi (es. ricerca, apertura file) e riceve dati tramite", "Electron IPC")
Rel(main, filesystem, "Legge l'archivio DIP ed esporta i file estratti su", "Node.js fs")
Rel(main, sqlite, "Esegue query SQL su", "Driver SQLite")
Rel(main, sqlite_vss, "Esegue query di ricerca vettoriale su", "Driver SQLite")
Rel(main, llm_models, "Carica i modelli in memoria tramite", "ONNX Runtime")
Rel(main, printer, "Invia documenti per la stampa tramite", "Node.js print API")

@enduml